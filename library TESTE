-- ────────────────────────────────────────────────
-- Component: Dropdown
-- ────────────────────────────────────────────────
function Components.Dropdown(parent, opts, multi)
    opts = opts or {}
    local id = Utilities:UID()
    local group = Cleanup:Group(id)
    local isMulti = multi == true

    local options = opts.Options or {}
    local selected = State:New(isMulti and {} or (opts.Default or nil))
    local isOpen = false

    local ITEM_H = 36
    local H = Theme:Get("ComponentHeight") + 8

    local container = Utilities:Frame({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Size = UDim2.new(1, 0, 0, H),
        Parent = parent,
        Name = (isMulti and "Multi" or "") .. "Dropdown_" .. id,
    })

    local headerBtn = Utilities:Button({
        Color = Theme:Get("Surface"),
        Text = "",
        Size = UDim2.new(1, -(Theme:Get("Padding") * 2), 0, Theme:Get("ComponentHeight")),
        Position = UDim2.new(0, Theme:Get("Padding"), 0, 4),
        Parent = container,
    })
    headerBtn.ClipsDescendants = false
    Utilities:Corner(headerBtn, Theme:Get("Radius"))
    Utilities:Stroke(headerBtn, Theme:Get("Border"), 1)

    local titleLbl = Utilities:Label({
        Text = opts.Title or (isMulti and "Multi Select" or "Dropdown"),
        Color = Theme:Get("TextSecondary"),
        Font = Theme:Get("FontBody"),
        Size = Theme:Get("SizeSmall"),
        FrameSize = UDim2.new(1, -32, 1, 0),
        Position = UDim2.new(0, Theme:Get("PaddingSmall"), 0, 0),
        Parent = headerBtn,
    })

    local arrow = Utilities:Label({
        Text = "▾",
        Color = Theme:Get("TextSecondary"),
        Font = Theme:Get("FontBody"),
        Size = Theme:Get("SizeBody"),
        XAlign = Enum.TextXAlignment.Center,
        FrameSize = UDim2.new(0, 24, 1, 0),
        Position = UDim2.new(1, -28, 0, 0),
        Parent = headerBtn,
    })

    -- Dropdown list (rendered in container parent to avoid clipping)
    local listFrame = Utilities:Frame({
        Color = Theme:Get("BackgroundAlt"),
        Size = UDim2.new(1, -(Theme:Get("Padding") * 2), 0, 0),
        Position = UDim2.new(0, Theme:Get("Padding"), 0, H + 2),
        Clip = true,
        Parent = container,
    })
    Utilities:Corner(listFrame, Theme:Get("Radius"))
    Utilities:Stroke(listFrame, Theme:Get("Border"), 1)
    listFrame.ZIndex = 10

    local listLayout = Utilities:ListLayout(listFrame, nil, 0)
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder

    local function getDisplayText()
        if isMulti then
            local sel = selected:Get()
            if #sel == 0 then return opts.Title or "Select..." end
            return table.concat(sel, ", ")
        else
            return selected:Get() or (opts.Title or "Select...")
        end
    end

    local function isSelected(opt)
        if isMulti then
            for _, v in ipairs(selected:Get()) do
                if v == opt then return true end
            end
            return false
        else
            return selected:Get() == opt
        end
    end

    local function buildItems()
        -- Clear existing
        for _, c in ipairs(listFrame:GetChildren()) do
            if c:IsA("TextButton") or c:IsA("Frame") then
                c:Destroy()
            end
        end

        for i, opt in ipairs(options) do
            local itemBtn = Utilities:Button({
                Color = Color3.fromRGB(0,0,0),
                Transparency = 1,
                Text = "",
                Size = UDim2.new(1, 0, 0, ITEM_H),
                Parent = listFrame,
            })
            itemBtn.LayoutOrder = i
            itemBtn.ZIndex = 11

            local checkLbl = Utilities:Label({
                Text = isSelected(opt) and "✓" or "",
                Color = Theme:Get("Accent"),
                Font = Theme:Get("FontSemibold"),
                Size = Theme:Get("SizeBody"),
                XAlign = Enum.TextXAlignment.Center,
                FrameSize = UDim2.new(0, 24, 1, 0),
                Position = UDim2.new(0, 4, 0, 0),
                Parent = itemBtn,
            })
            checkLbl.ZIndex = 12

            local optLbl = Utilities:Label({
                Text = tostring(opt),
                Color = isSelected(opt) and Theme:Get("TextPrimary") or Theme:Get("TextSecondary"),
                Font = Theme:Get("FontBody"),
                Size = Theme:Get("SizeBody"),
                FrameSize = UDim2.new(1, -32, 1, 0),
                Position = UDim2.new(0, 32, 0, 0),
                Parent = itemBtn,
            })
            optLbl.ZIndex = 12

            -- Hover
            local hoverConns = Utilities:AddHover(itemBtn,
                Color3.fromRGB(0,0,0),
                Theme:Get("SurfaceHover")
            )
            -- Don't need to cleanup these since they go with itemBtn

            group:AddConnection(itemBtn.MouseButton1Click:Connect(function()
                if isMulti then
                    local sel = Utilities:DeepCopy(selected:Get())
                    local found = false
                    for i2, v in ipairs(sel) do
                        if v == opt then
                            table.remove(sel, i2)
                            found = true
                            break
                        end
                    end
                    if not found then table.insert(sel, opt) end
                    selected:Set(sel)
                    if opts.Callback then task.spawn(opts.Callback, sel) end
                else
                    selected:Set(opt)
                    if opts.Callback then task.spawn(opts.Callback, opt) end
                    -- Close after single select
                    task.defer(function()
                        if isOpen then
                            headerBtn:GetPropertyChangedSignal("AbsolutePosition"):Wait()
                        end
                    end)
                    isOpen = true -- will flip below
                    headerBtn:GetPropertyChangedSignal("AbsoluteSize"):Wait()
                end
                titleLbl.Text = getDisplayText()
                buildItems()
                if not isMulti then
                    -- Close
                    isOpen = false
                    Animations:TweenFast(listFrame, { Size = UDim2.new(1, -(Theme:Get("Padding") * 2), 0, 0) })
                    Animations:TweenFast(arrow, { Rotation = 0 })
                end
                Events:Fire("Dropdown.Changed", id, selected:Get())
            end))
        end

        -- Update list size
        local totalH = #options * ITEM_H
        if isOpen then
            listFrame.Size = UDim2.new(1, -(Theme:Get("Padding") * 2), 0, totalH)
        end
    end

    buildItems()

    local function toggle()
        isOpen = not isOpen
        local targetH = isOpen and (#options * ITEM_H) or 0
        Animations:TweenFast(listFrame, { Size = UDim2.new(1, -(Theme:Get("Padding") * 2), 0, targetH) })
        Animations:TweenFast(arrow, { Rotation = isOpen and 180 or 0 })
        if isOpen then buildItems() end
    end

    group:AddConnection(headerBtn.MouseButton1Click:Connect(toggle))

    -- Hover
    local hConns = Utilities:AddHover(headerBtn, Theme:Get("Surface"), Theme:Get("SurfaceHover"))
    for _, c in ipairs(hConns) do group:AddConnection(c) end

    local component = { Instance = container, _id = id, _value = selected }

    function component:GetValue()
        return selected:Get()
    end

    function component:SetValue(v, silent)
        selected:Set(v)
        titleLbl.Text = getDisplayText()
        buildItems()
        if not silent and opts.Callback then
            task.spawn(opts.Callback, v)
        end
    end

    function component:SetOptions(newOptions)
        options = newOptions
        buildItems()
    end

    function component:Destroy()
        selected:Destroy()
        group:Destroy()
        container:Destroy()
    end

    return component
end

-- MultiDropdown alias
function Components.MultiDropdown(parent, opts)
    return Components.Dropdown(parent, opts, true)
end

