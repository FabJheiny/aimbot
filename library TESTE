-- Component: Slider
-- ────────────────────────────────────────────────
function Components.Slider(parent, opts)
    opts = opts or {}
    local id = Utilities:UID()
    local group = Cleanup:Group(id)

    local minV = opts.Min or 0
    local maxV = opts.Max or 100
    local step = opts.Step or 1
    local initV = math.clamp(opts.Value or minV, minV, maxV)
    local value = State:New(initV)
    local suffix = opts.Suffix or ""

    local TRACK_H = 4
    local THUMB_SIZE = 18
    local H = Theme:Get("ComponentHeight") + 20

    local container = Utilities:Frame({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Size = UDim2.new(1, 0, 0, H),
        Parent = parent,
        Name = "Slider_" .. id,
    })

    local topRow = Utilities:Frame({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Size = UDim2.new(1, 0, 0, 20),
        Parent = container,
    })

    local titleLbl = Utilities:Label({
        Text = opts.Title or "Slider",
        Color = Theme:Get("TextPrimary"),
        Font = Theme:Get("FontBody"),
        Size = Theme:Get("SizeBody"),
        FrameSize = UDim2.new(1, -60, 1, 0),
        Position = UDim2.new(0, Theme:Get("Padding"), 0, 0),
        Parent = topRow,
    })

    local valLbl = Utilities:Label({
        Text = tostring(initV) .. suffix,
        Color = Theme:Get("TextSecondary"),
        Font = Theme:Get("FontMono"),
        Size = Theme:Get("SizeSmall"),
        XAlign = Enum.TextXAlignment.Right,
        FrameSize = UDim2.new(0, 50, 1, 0),
        Position = UDim2.new(1, -(50 + Theme:Get("Padding")), 0, 0),
        Parent = topRow,
    })

    local trackArea = Utilities:Frame({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Size = UDim2.new(1, -(Theme:Get("Padding") * 2), 0, THUMB_SIZE),
        Position = UDim2.new(0, Theme:Get("Padding"), 0, 24),
        Parent = container,
        Clip = false,
    })

    local track = Utilities:Frame({
        Color = Theme:Get("SliderTrack"),
        Size = UDim2.new(1, 0, 0, TRACK_H),
        Position = UDim2.new(0, 0, 0.5, -(TRACK_H // 2)),
        Parent = trackArea,
    })
    Utilities:Corner(track, TRACK_H // 2)

    local fill = Utilities:Frame({
        Color = Theme:Get("SliderFill"),
        Size = UDim2.new((initV - minV) / (maxV - minV), 0, 1, 0),
        Position = UDim2.new(0, 0, 0, 0),
        Parent = track,
    })
    Utilities:Corner(fill, TRACK_H // 2)

    local thumb = Utilities:Frame({
        Color = Theme:Get("SliderThumb"),
        Size = UDim2.new(0, THUMB_SIZE, 0, THUMB_SIZE),
        Position = UDim2.new((initV - minV) / (maxV - minV), -(THUMB_SIZE // 2), 0.5, -(THUMB_SIZE // 2)),
        Parent = track,
    })
    Utilities:Corner(thumb, THUMB_SIZE // 2)

    -- Hit area
    local hitBtn = Utilities:Button({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Text = "",
        Size = UDim2.new(1, 0, 0, THUMB_SIZE + 8),
        Position = UDim2.new(0, 0, 0.5, -((THUMB_SIZE + 8) // 2)),
        Parent = trackArea,
    })

    local dragging = false

    local function setFromAlpha(alpha)
        alpha = math.clamp(alpha, 0, 1)
        local raw = minV + alpha * (maxV - minV)
        local stepped = math.round(raw / step) * step
        local clamped = math.clamp(stepped, minV, maxV)
        -- Round to avoid floating point noise
        clamped = math.round(clamped * 1000) / 1000
        value:Set(clamped)
        local a = (clamped - minV) / (maxV - minV)
        fill.Size = UDim2.new(a, 0, 1, 0)
        thumb.Position = UDim2.new(a, -(THUMB_SIZE // 2), 0.5, -(THUMB_SIZE // 2))
        valLbl.Text = tostring(clamped) .. suffix
        if opts.Callback then
            task.spawn(opts.Callback, clamped)
        end
    end

    local function alphaFromInput(input)
        local trackPos = track.AbsolutePosition.X
        local trackW = track.AbsoluteSize.X
        local x = input.Position.X - trackPos
        return x / trackW
    end

    local downConn = group:AddConnection(hitBtn.MouseButton1Down:Connect(function(x, y)
        dragging = true
        local alpha = (x - track.AbsolutePosition.X) / track.AbsoluteSize.X
        setFromAlpha(alpha)
    end))

    local moveConn = group:AddConnection(UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local alpha = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
            setFromAlpha(alpha)
        end
    end))

    local upConn = group:AddConnection(UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end))

    local component = { Instance = container, _id = id, _value = value }

    function component:GetValue()
        return value:Get()
    end

    function component:SetValue(v, silent)
        local a = math.clamp((v - minV) / (maxV - minV), 0, 1)
        setFromAlpha(a)
        if silent then
            -- override callback firing that setFromAlpha does
        end
    end

    function component:SetTitle(text)
        titleLbl.Text = text
    end

    function component:Destroy()
        value:Destroy()
        group:Destroy()
        container:Destroy()
    end

    return component
end

