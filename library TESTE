        Font = Theme:Get("FontBody"),
        Size = Theme:Get("SizeBody"),
        FrameSize = UDim2.new(1, -(TRACK_W + Theme:Get("Padding") * 2 + 8), 1, 0),
        Position = UDim2.new(0, Theme:Get("Padding"), 0, 0),
        Parent = hitBtn,
    })

    -- Track
    local track = Utilities:Frame({
        Color = value:Get() and Theme:Get("ToggleOn") or Theme:Get("ToggleOff"),
        Size = UDim2.new(0, TRACK_W, 0, TRACK_H),
        Position = UDim2.new(1, -(TRACK_W + Theme:Get("Padding")), 0.5, -(TRACK_H // 2)),
        Parent = hitBtn,
    })
    Utilities:Corner(track, TRACK_H // 2)

    -- Thumb
    local thumb = Utilities:Frame({
        Color = Theme:Get("ToggleThumb"),
        Size = UDim2.new(0, THUMB_SIZE, 0, THUMB_SIZE),
        Position = UDim2.new(0, value:Get() and THUMB_ON_X or THUMB_OFF, 0.5, -(THUMB_SIZE // 2)),
        Parent = track,
    })
    Utilities:Corner(thumb, THUMB_SIZE // 2)

    local function applyState(on, animate)
        if animate then
            Animations:TweenFast(track, { BackgroundColor3 = on and Theme:Get("ToggleOn") or Theme:Get("ToggleOff") })
            Animations:TweenFast(thumb, { Position = UDim2.new(0, on and THUMB_ON_X or THUMB_OFF, 0.5, -(THUMB_SIZE // 2)) })
        else
            track.BackgroundColor3 = on and Theme:Get("ToggleOn") or Theme:Get("ToggleOff")
            thumb.Position = UDim2.new(0, on and THUMB_ON_X or THUMB_OFF, 0.5, -(THUMB_SIZE // 2))
        end
    end

    local clickConn = group:AddConnection(hitBtn.MouseButton1Click:Connect(function()
        local newVal = not value:Get()
        value:Set(newVal)
        applyState(newVal, true)
        if opts.Callback then
            task.spawn(opts.Callback, newVal)
        end
        Events:Fire("Toggle.Changed", id, newVal)
    end))

    local component = { Instance = container, _id = id, _value = value }

    function component:GetValue()
        return value:Get()
    end

    function component:SetValue(v, silent)
        value:Set(v)
        applyState(v, true)
        if not silent and opts.Callback then
            task.spawn(opts.Callback, v)
        end
    end

    function component:SetTitle(text)
        titleLbl.Text = text
    end

    function component:Destroy()
        value:Destroy()
        group:Destroy()
        container:Destroy()
    end

    return component
end

