    Utilities:Stroke(panel, Theme:Get("Border"), 1)
    panel.ZIndex = 10

    local function getColor()
        return Color3.fromHSV(hState:Get(), sState:Get(), vState:Get())
    end

    -- Saturation/Value area
    local svFrame = Utilities:Frame({
        Color = Color3.fromHSV(hState:Get(), 1, 1),
        Size = UDim2.new(1, -16, 0, SAT_H),
        Position = UDim2.new(0, 8, 0, 8),
        Parent = panel,
    })
    Utilities:Corner(svFrame, 4)

    -- White gradient overlay
    local whiteGrad = Instance.new("UIGradient")
    whiteGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255,255,255)),
    })
    whiteGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0),
        NumberSequenceKeypoint.new(1, 1),
    })
    whiteGrad.Parent = svFrame

    local blackGrad = Instance.new("UIGradient")
    blackGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0,0,0)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0)),
    })
    blackGrad.Rotation = 90
    blackGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 1),
        NumberSequenceKeypoint.new(1, 0),
    })

    local svOverlay = Utilities:Frame({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = svFrame,
    })
    blackGrad.Parent = svOverlay

    local svCursor = Utilities:Frame({
        Color = Color3.fromRGB(255,255,255),
        Size = UDim2.new(0, 10, 0, 10),
        Position = UDim2.new(sState:Get(), -5, 1 - vState:Get(), -5),
        Parent = svFrame,
    })
    Utilities:Corner(svCursor, 5)
    Utilities:Stroke(svCursor, Color3.fromRGB(0,0,0), 1)

    -- Hue bar
    local hueBar = Utilities:Frame({
        Color = Color3.fromRGB(255,255,255),
        Size = UDim2.new(1, -16, 0, HUE_H),
        Position = UDim2.new(0, 8, 0, SAT_H + 16),
        Parent = panel,
    })
    Utilities:Corner(hueBar, HUE_H // 2)

    local hueGrad = Instance.new("UIGradient")
    hueGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0/6, Color3.fromHSV(0/6, 1, 1)),
        ColorSequenceKeypoint.new(1/6, Color3.fromHSV(1/6, 1, 1)),
        ColorSequenceKeypoint.new(2/6, Color3.fromHSV(2/6, 1, 1)),
        ColorSequenceKeypoint.new(3/6, Color3.fromHSV(3/6, 1, 1)),
        ColorSequenceKeypoint.new(4/6, Color3.fromHSV(4/6, 1, 1)),
        ColorSequenceKeypoint.new(5/6, Color3.fromHSV(5/6, 1, 1)),
        ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
    })
    hueGrad.Parent = hueBar

    local hueCursor = Utilities:Frame({
        Color = Color3.fromRGB(255,255,255),
        Size = UDim2.new(0, 8, 1, 4),
        Position = UDim2.new(hState:Get(), -4, 0, -2),
        Parent = hueBar,
    })
    Utilities:Corner(hueCursor, 4)
    Utilities:Stroke(hueCursor, Color3.fromRGB(0,0,0), 1)

    local function updateVisuals()
        local col = getColor()
        preview.BackgroundColor3 = col
        svFrame.BackgroundColor3 = Color3.fromHSV(hState:Get(), 1, 1)
        svCursor.Position = UDim2.new(sState:Get(), -5, 1 - vState:Get(), -5)
        hueCursor.Position = UDim2.new(hState:Get(), -4, 0, -2)
        if opts.Callback then
            task.spawn(opts.Callback, col)
        end
        Events:Fire("ColorPicker.Changed", id, col)
    end

    -- SV drag
    local svDragging = false
    local svHitBtn = Utilities:Button({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Text = "",
        Size = UDim2.new(1, 0, 1, 0),
        Parent = svFrame,
    })
    svHitBtn.ZIndex = 12

    group:AddConnection(svHitBtn.MouseButton1Down:Connect(function()
        svDragging = true
    end))

    group:AddConnection(UserInputService.InputChanged:Connect(function(input)
        if svDragging and (input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local pos = svFrame.AbsolutePosition
            local size = svFrame.AbsoluteSize
            local relX = math.clamp((input.Position.X - pos.X) / size.X, 0, 1)
            local relY = math.clamp((input.Position.Y - pos.Y) / size.Y, 0, 1)
            sState:Set(relX)
            vState:Set(1 - relY)
            updateVisuals()
        end
    end))

    -- Hue drag
    local hueDragging = false
    local hueHitBtn = Utilities:Button({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Text = "",
        Size = UDim2.new(1, 0, 1, 0),
        Parent = hueBar,
    })
    hueHitBtn.ZIndex = 12

    group:AddConnection(hueHitBtn.MouseButton1Down:Connect(function(x)
        hueDragging = true
        local relX = math.clamp((x - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
        hState:Set(relX)
        updateVisuals()
    end))

    group:AddConnection(UserInputService.InputChanged:Connect(function(input)
        if hueDragging and (input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local relX = math.clamp((input.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
            hState:Set(relX)
            updateVisuals()
        end
    end))

    group:AddConnection(UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            svDragging = false
            hueDragging = false
        end
    end))

    local function togglePicker()
        isOpen = not isOpen
        local targetH = isOpen and (PICKER_H) or 0
        container.Size = UDim2.new(1, 0, 0, Theme:Get("ComponentHeight") + (isOpen and (PICKER_H + 8) or 0))
        Animations:TweenFast(panel, { Size = UDim2.new(1, -(Theme:Get("Padding") * 2), 0, targetH) })
    end

    group:AddConnection(headerBtn.MouseButton1Click:Connect(togglePicker))

    local component = { Instance = container, _id = id }

    function component:GetValue()
        return getColor()
    end

    function component:SetValue(color)
        local nh, ns, nv = Color3.toHSV(color)
        hState:Set(nh)
        sState:Set(ns)
        vState:Set(nv)
        updateVisuals()
    end

    function component:Destroy()
        hState:Destroy()
        sState:Destroy()
        vState:Destroy()
        group:Destroy()
        container:Destroy()
    end

    return component
end

