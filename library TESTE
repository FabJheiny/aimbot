        ToggleOff        = Color3.fromRGB(50, 50, 50),
        ToggleThumb      = Color3.fromRGB(10, 10, 10),

        -- Slider
        SliderTrack      = Color3.fromRGB(40, 40, 40),
        SliderFill       = Color3.fromRGB(255, 255, 255),
        SliderThumb      = Color3.fromRGB(255, 255, 255),

        -- Transparency
        WindowBg         = 0,
        OverlayBg        = 0.5,

        -- Typography
        FontTitle        = Enum.Font.GothamBold,
        FontSemibold     = Enum.Font.GothamSemibold,
        FontBody         = Enum.Font.Gotham,
        FontMono         = Enum.Font.Code,

        SizeTitle        = 14,
        SizeBody         = 12,
        SizeSmall        = 11,
        SizeCaption      = 10,

        -- Spacing
        Padding          = 12,
        PaddingSmall     = 8,
        PaddingLarge     = 16,
        Radius           = 6,
        RadiusSmall      = 4,
        RadiusLarge      = 8,

        -- Animation
        TweenFast        = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        TweenMedium      = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        TweenSlow        = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        TweenBounce      = TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out),

        -- Layout
        WindowWidth      = 320,
        WindowMinHeight  = 200,
        ComponentHeight  = 44,
        TabHeight        = 36,
        HeaderHeight     = 48,
    }

    local listeners = {}

    function self:Get(key)
        return self.Data[key]
    end

    function self:Set(overrides)
        for k, v in pairs(overrides) do
            self.Data[k] = v
        end
        for _, fn in ipairs(listeners) do
            pcall(fn, self.Data)
        end
    end

    function self:OnChanged(fn)
        table.insert(listeners, fn)
        return function()
            for i, v in ipairs(listeners) do
                if v == fn then table.remove(listeners, i) break end
            end
        end
    end

    return self
end)()

-- ============================================================
-- CONFIG MODULE  (Persistence via pcall-safe JSON)
-- ============================================================
local Config = (function()
    local self = {}
    local store = {}
    local KEY_PREFIX = "ApexUI_"

    local function safeGet(key)
        local ok, result = pcall(function()
            return game:GetService("Players").LocalPlayer
                and require ~= nil and false
        end)
        return nil
    end

    function self:Save(name, data)
        store[name] = data
        -- Attempt writefile if executor supports it
        local ok = pcall(function()
            if writefile then
                writefile(KEY_PREFIX .. name .. ".json", HttpService:JSONEncode(data))
            end
        end)
        return ok
    end

    function self:Load(name)
        -- Attempt readfile if executor supports it
        local ok, result = pcall(function()
            if readfile then
                local raw = readfile(KEY_PREFIX .. name .. ".json")
                return HttpService:JSONDecode(raw)
            end
        end)
        if ok and result then return result end
        return store[name]
    end

    function self:GetStore()
        return store
    end

    return self
end)()

-- ============================================================
-- EVENTS MODULE  (Lightweight signal system)
-- ============================================================
local Events = (function()
    local self = {}
    local registry = {}

    function self:New(name)
        if not registry[name] then
            registry[name] = {}
        end
        return {
            Fire = function(_, ...)
                local args = {...}
                for _, fn in ipairs(registry[name] or {}) do
                    task.spawn(fn, table.unpack(args))
                end
            end,
            Connect = function(_, fn)
                table.insert(registry[name], fn)
                return function()
                    for i, v in ipairs(registry[name]) do
                        if v == fn then table.remove(registry[name], i) break end
                    end
                end
            end,
        }
    end

    function self:Fire(name, ...)
        local args = {...}
        for _, fn in ipairs(registry[name] or {}) do
            task.spawn(fn, table.unpack(args))
        end
    end

    function self:Connect(name, fn)
        if not registry[name] then registry[name] = {} end
        table.insert(registry[name], fn)
        return function()
            for i, v in ipairs(registry[name]) do
                if v == fn then table.remove(registry[name], i) break end
            end
        end
    end

    function self:Clear(name)
        registry[name] = {}
    end

    return self
end)()

-- ============================================================
-- CLEANUP MODULE  (Centralized resource management)
-- ============================================================
local Cleanup = (function()
    local self = {}
    local groups = {}

    function self:Group(id)
        if not groups[id] then
            groups[id] = { connections = {}, instances = {}, tweens = {}, tasks = {} }
        end
        return {
            AddConnection = function(_, conn)
                table.insert(groups[id].connections, conn)
                return conn
            end,
            AddInstance = function(_, inst)
                table.insert(groups[id].instances, inst)
                return inst
            end,
            AddTween = function(_, tw)
                table.insert(groups[id].tweens, tw)
                return tw
            end,
            AddTask = function(_, t)
                table.insert(groups[id].tasks, t)
                return t
            end,
            Destroy = function(_)
                self:DestroyGroup(id)
            end,
        }
    end

    function self:DestroyGroup(id)
        local g = groups[id]
        if not g then return end
        for _, conn in ipairs(g.connections) do
            if typeof(conn) == "RBXScriptConnection" then
                pcall(function() conn:Disconnect() end)
            elseif type(conn) == "function" then
                pcall(conn)
            end
        end
        for _, tw in ipairs(g.tweens) do
            pcall(function() tw:Cancel() end)
        end
        for _, t in ipairs(g.tasks) do
            pcall(function() task.cancel(t) end)
        end
        for _, inst in ipairs(g.instances) do
            pcall(function() inst:Destroy() end)
        end
        groups[id] = nil
    end

    function self:DestroyAll()
        for id in pairs(groups) do
            self:DestroyGroup(id)
        end
    end

    return self
end)()

-- ============================================================
-- ANIMATIONS MODULE  (Pooled tween helpers)
-- ============================================================
local Animations = (function()
    local self = {}
    local pool = {}
    local MAX_POOL = 20

    local function getTween(inst, info, props)
        -- Cancel any existing tween on instance
        if pool[inst] then
            pcall(function() pool[inst]:Cancel() end)
        end
        local tw = TweenService:Create(inst, info, props)
        pool[inst] = tw
        tw.Completed:Connect(function()
            if pool[inst] == tw then
                pool[inst] = nil
            end
        end)
        return tw
    end

    function self:Tween(inst, info, props)
        local tw = getTween(inst, info, props)
        tw:Play()
        return tw
    end

    function self:TweenFast(inst, props)
        return self:Tween(inst, Theme:Get("TweenFast"), props)
    end

    function self:TweenMedium(inst, props)
        return self:Tween(inst, Theme:Get("TweenMedium"), props)
    end

    function self:TweenSlow(inst, props)
        return self:Tween(inst, Theme:Get("TweenSlow"), props)
    end

    function self:TweenBounce(inst, props)
        return self:Tween(inst, Theme:Get("TweenBounce"), props)
    end

    function self:CancelAll()
        for inst, tw in pairs(pool) do
            pcall(function() tw:Cancel() end)
        end
        pool = {}
    end

    return self
end)()

-- ============================================================
-- UTILITIES MODULE
-- ============================================================
local Utilities = (function()
    local self = {}

    -- Create a UICorner
    function self:Corner(parent, radius)
        local c = Instance.new("UICorner")
        c.CornerRadius = UDim.new(0, radius or Theme:Get("Radius"))
        c.Parent = parent
        return c
    end

    -- Create a UIStroke
    function self:Stroke(parent, color, thickness)
        local s = Instance.new("UIStroke")
        s.Color = color or Theme:Get("Border")
        s.Thickness = thickness or 1
        s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        s.Parent = parent
        return s
    end

    -- Create a UIPadding
    function self:Padding(parent, top, right, bottom, left)
        local p = Instance.new("UIPadding")
        p.PaddingTop    = UDim.new(0, top    or Theme:Get("Padding"))
        p.PaddingRight  = UDim.new(0, right  or Theme:Get("Padding"))
        p.PaddingBottom = UDim.new(0, bottom or Theme:Get("Padding"))
        p.PaddingLeft   = UDim.new(0, left   or Theme:Get("Padding"))
        p.Parent = parent
        return p
    end

    -- Create a UIListLayout
    function self:ListLayout(parent, direction, padding, align)
        local l = Instance.new("UIListLayout")
        l.FillDirection     = direction or Enum.FillDirection.Vertical
        l.Padding           = UDim.new(0, padding or 0)
        l.HorizontalAlignment = align or Enum.HorizontalAlignment.Left
        l.SortOrder         = Enum.SortOrder.LayoutOrder
        l.Parent            = parent
        return l
    end

    -- Create Frame
    function self:Frame(props)
        local f = Instance.new("Frame")
        f.BackgroundColor3 = props.Color or Theme:Get("Surface")
        f.BackgroundTransparency = props.Transparency or 0
        f.BorderSizePixel = 0
        f.Size = props.Size or UDim2.new(1, 0, 0, 40)
        f.Position = props.Position or UDim2.new(0, 0, 0, 0)
        f.ClipsDescendants = props.Clip ~= nil and props.Clip or false
        if props.Name then f.Name = props.Name end
        if props.Parent then f.Parent = props.Parent end
        return f
    end

    -- Create TextLabel
    function self:Label(props)
        local l = Instance.new("TextLabel")
        l.BackgroundTransparency = 1
        l.TextColor3 = props.Color or Theme:Get("TextPrimary")
        l.Font = props.Font or Theme:Get("FontBody")
        l.TextSize = props.Size or Theme:Get("SizeBody")
        l.Text = props.Text or ""
        l.TextXAlignment = props.XAlign or Enum.TextXAlignment.Left
        l.TextYAlignment = props.YAlign or Enum.TextYAlignment.Center
        l.TextTruncate = props.Truncate or Enum.TextTruncate.AtEnd
        l.RichText = props.Rich or false
        l.Size = props.FrameSize or UDim2.new(1, 0, 1, 0)
        l.Position = props.Position or UDim2.new(0, 0, 0, 0)
        if props.Name then l.Name = props.Name end
        if props.Parent then l.Parent = props.Parent end
        return l
    end

    -- Create TextButton
    function self:Button(props)
        local b = Instance.new("TextButton")
        b.BackgroundColor3 = props.Color or Theme:Get("Surface")
        b.BackgroundTransparency = props.Transparency or 0
        b.BorderSizePixel = 0
        b.TextColor3 = props.TextColor or Theme:Get("TextPrimary")
        b.Font = props.Font or Theme:Get("FontBody")
        b.TextSize = props.TextSize or Theme:Get("SizeBody")
        b.Text = props.Text or ""
        b.AutoButtonColor = false
        b.Size = props.Size or UDim2.new(1, 0, 0, Theme:Get("ComponentHeight"))
        b.Position = props.Position or UDim2.new(0, 0, 0, 0)
        if props.Name then b.Name = props.Name end
        if props.Parent then b.Parent = props.Parent end
        return b
    end

    -- Create TextBox
    function self:TextBox(props)
        local t = Instance.new("TextBox")
        t.BackgroundColor3 = props.Color or Theme:Get("SurfaceHover")
        t.BackgroundTransparency = props.Transparency or 0
        t.BorderSizePixel = 0
        t.TextColor3 = props.TextColor or Theme:Get("TextPrimary")
        t.PlaceholderColor3 = props.PlaceholderColor or Theme:Get("TextDisabled")
        t.Font = props.Font or Theme:Get("FontBody")
        t.TextSize = props.TextSize or Theme:Get("SizeBody")
        t.Text = props.Text or ""
        t.PlaceholderText = props.Placeholder or ""
        t.ClearTextOnFocus = props.ClearOnFocus ~= nil and props.ClearOnFocus or false
        t.MultiLine = props.MultiLine or false
        t.Size = props.Size or UDim2.new(1, 0, 0, Theme:Get("ComponentHeight"))
        t.Position = props.Position or UDim2.new(0, 0, 0, 0)
        t.TextXAlignment = props.XAlign or Enum.TextXAlignment.Left
        if props.Name then t.Name = props.Name end
        if props.Parent then t.Parent = props.Parent end
        return t
    end

    -- Viewport safe area
    function self:GetSafeArea()
        local vp = workspace.CurrentCamera.ViewportSize
        local inset = UserInputService:GetGuiInset()
        return {
            Width  = vp.X,
            Height = vp.Y,
            InsetTop = inset.Y,
        }
    end

    -- Clamp position within screen
    function self:ClampPosition(pos, size, safe)
        safe = safe or self:GetSafeArea()
        local x = math.clamp(pos.X.Offset, 0, safe.Width  - size.X.Offset)
        local y = math.clamp(pos.Y.Offset, safe.InsetTop, safe.Height - size.Y.Offset)
        return UDim2.new(0, x, 0, y)
    end

    -- Generate unique ID
    function self:UID()
        return HttpService:GenerateGUID(false):sub(1, 8)
    end

    -- Deep copy table
    function self:DeepCopy(t)
        local copy = {}
        for k, v in pairs(t) do
            copy[k] = type(v) == "table" and self:DeepCopy(v) or v
        end
        return copy
    end

    -- Ripple effect on button press
    function self:Ripple(parent, x, y)
        local ripple = Instance.new("Frame")
        ripple.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        ripple.BackgroundTransparency = 0.85
        ripple.BorderSizePixel = 0
        ripple.Size = UDim2.new(0, 0, 0, 0)
        ripple.Position = UDim2.new(0, x, 0, y)
        ripple.AnchorPoint = Vector2.new(0.5, 0.5)
        ripple.ZIndex = parent.ZIndex + 10
        ripple.Parent = parent
        self:Corner(ripple, 9999)

        local size = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2
        Animations:TweenMedium(ripple, {
            Size = UDim2.new(0, size, 0, size),
            BackgroundTransparency = 1,
        }).Completed:Connect(function()
            ripple:Destroy()
        end)
    end

    -- Hover state helpers
    function self:AddHover(inst, normalColor, hoverColor)
        local conn1 = inst.MouseEnter:Connect(function()
            Animations:TweenFast(inst, { BackgroundColor3 = hoverColor })
        end)
        local conn2 = inst.MouseLeave:Connect(function()
            Animations:TweenFast(inst, { BackgroundColor3 = normalColor })
        end)
        return { conn1, conn2 }
    end

    return self
end)()

-- ============================================================
-- STATE MODULE  (Reactive state container)
-- ============================================================
local State = (function()
    local self = {}

    function self:New(initial)
        local state = {
            _value = initial,
            _listeners = {},
        }

        function state:Get()
            return self._value
        end

        function state:Set(newVal)
            local old = self._value
            self._value = newVal
            if old ~= newVal then
                for _, fn in ipairs(self._listeners) do
                    task.spawn(fn, newVal, old)
                end
            end
        end

        function state:Subscribe(fn)
            table.insert(self._listeners, fn)
            return function()
                for i, v in ipairs(self._listeners) do
                    if v == fn then table.remove(self._listeners, i) break end
                end
            end
        end

        function state:Destroy()
            self._listeners = {}
        end

        return state
    end

    return self
end)()

