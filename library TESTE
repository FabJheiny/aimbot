        TextSecondary    = Color3.fromRGB(160, 160, 160),
        TextDisabled     = Color3.fromRGB(80, 80, 80),
        TextInverse      = Color3.fromRGB(10, 10, 10),

        -- Accent
        Accent           = Color3.fromRGB(255, 255, 255),
        AccentDim        = Color3.fromRGB(180, 180, 180),
        AccentMuted      = Color3.fromRGB(60, 60, 60),

