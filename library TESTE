-- Component: Keybind
-- ────────────────────────────────────────────────
function Components.Keybind(parent, opts)
    opts = opts or {}
    local id = Utilities:UID()
    local group = Cleanup:Group(id)

    local currentKey = State:New(opts.Default or Enum.KeyCode.Unknown)
    local listening = false

    local container = Utilities:Frame({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Size = UDim2.new(1, 0, 0, Theme:Get("ComponentHeight")),
        Parent = parent,
        Name = "Keybind_" .. id,
    })

    local titleLbl = Utilities:Label({
        Text = opts.Title or "Keybind",
        Color = Theme:Get("TextPrimary"),
        Font = Theme:Get("FontBody"),
        Size = Theme:Get("SizeBody"),
        FrameSize = UDim2.new(1, -100, 1, 0),
        Position = UDim2.new(0, Theme:Get("Padding"), 0, 0),
        Parent = container,
    })

    local keyBtn = Utilities:Button({
        Color = Theme:Get("SurfaceHover"),
        Text = currentKey:Get() ~= Enum.KeyCode.Unknown and currentKey:Get().Name or "None",
        TextSize = Theme:Get("SizeSmall"),
        TextColor = Theme:Get("TextSecondary"),
        Font = Theme:Get("FontMono"),
        Size = UDim2.new(0, 80, 0, 28),
        Position = UDim2.new(1, -(80 + Theme:Get("Padding")), 0.5, -14),
        Parent = container,
    })
    Utilities:Corner(keyBtn, Theme:Get("RadiusSmall"))
    Utilities:Stroke(keyBtn, Theme:Get("Border"), 1)

    local function setListening(v)
        listening = v
        if v then
            keyBtn.Text = "..."
            Animations:TweenFast(keyBtn, { BackgroundColor3 = Theme:Get("SurfaceActive") })
        else
            keyBtn.Text = currentKey:Get() ~= Enum.KeyCode.Unknown and currentKey:Get().Name or "None"
            Animations:TweenFast(keyBtn, { BackgroundColor3 = Theme:Get("SurfaceHover") })
        end
    end

    group:AddConnection(keyBtn.MouseButton1Click:Connect(function()
        setListening(not listening)
    end))

    group:AddConnection(UserInputService.InputBegan:Connect(function(input, gp)
        if not listening then
            -- Fire callback when key pressed
            if input.KeyCode == currentKey:Get() and not gp then
                if opts.Callback then
                    task.spawn(opts.Callback, input.KeyCode)
                end
            end
            return
        end
        if input.UserInputType == Enum.UserInputType.Keyboard then
            if input.KeyCode == Enum.KeyCode.Escape then
                currentKey:Set(Enum.KeyCode.Unknown)
            else
                currentKey:Set(input.KeyCode)
                if opts.Callback then
                    task.spawn(opts.Callback, input.KeyCode)
                end
            end
            setListening(false)
            Events:Fire("Keybind.Changed", id, currentKey:Get())
        end
    end))

    local component = { Instance = container, _id = id, _value = currentKey }

    function component:GetValue()
        return currentKey:Get()
    end

    function component:SetValue(key)
        currentKey:Set(key)
        setListening(false)
    end

    function component:Destroy()
        currentKey:Destroy()
        group:Destroy()
        container:Destroy()
    end

    return component
end

