    local lbl = Utilities:Label({
        Text = opts.Content or "",
        Color = Theme:Get("TextSecondary"),
        Font = Theme:Get("FontBody"),
        Size = Theme:Get("SizeBody"),
        FrameSize = UDim2.new(1, 0, 1, 0),
        Rich = true,
        Parent = container,
    })
    lbl.TextWrapped = true
    lbl.TextYAlignment = Enum.TextYAlignment.Top
    Utilities:Padding(lbl, 6, Theme:Get("Padding"), 6, Theme:Get("Padding"))

    -- Auto-size
    local function resize()
        local bounds = lbl.TextBounds
        container.Size = UDim2.new(1, 0, 0, bounds.Y + 16)
    end
    lbl:GetPropertyChangedSignal("TextBounds"):Connect(resize)

    local component = { Instance = container, Label = lbl }

    function component:SetContent(text)
        lbl.Text = text
    end

    function component:Destroy()
        container:Destroy()
    end

    return component
end

-- ────────────────────────────────────────────────
-- Component: Button
-- ────────────────────────────────────────────────
function Components.Button(parent, opts)
    opts = opts or {}
    local id = Utilities:UID()
    local group = Cleanup:Group(id)

    local container = Utilities:Frame({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Size = UDim2.new(1, 0, 0, Theme:Get("ComponentHeight") + 8),
        Parent = parent,
        Name = "Button_" .. id,
    })

    local btn = Utilities:Button({
        Color = Theme:Get("Surface"),
        Text = "",
        Size = UDim2.new(1, -(Theme:Get("Padding") * 2), 0, Theme:Get("ComponentHeight")),
        Position = UDim2.new(0, Theme:Get("Padding"), 0.5, -(Theme:Get("ComponentHeight") // 2)),
        Parent = container,
        Name = "Btn",
    })
    btn.ClipsDescendants = true
    Utilities:Corner(btn, Theme:Get("Radius"))
    Utilities:Stroke(btn, Theme:Get("Border"), 1)

    local lbl = Utilities:Label({
        Text = opts.Title or "Button",
        Color = opts.Style == "Primary" and Theme:Get("TextInverse") or Theme:Get("TextPrimary"),
        Font = Theme:Get("FontSemibold"),
        Size = Theme:Get("SizeBody"),
        XAlign = Enum.TextXAlignment.Center,
        FrameSize = UDim2.new(1, 0, 1, 0),
        Parent = btn,
    })

    if opts.Style == "Primary" then
        btn.BackgroundColor3 = Theme:Get("Accent")
    end

    -- Press animation
    local pressConn = group:AddConnection(btn.MouseButton1Down:Connect(function(x, y)
        local rel = Vector2.new(x - btn.AbsolutePosition.X, y - btn.AbsolutePosition.Y)
        Utilities:Ripple(btn, rel.X, rel.Y)
        Animations:TweenFast(btn, { BackgroundColor3 =
            opts.Style == "Primary" and Theme:Get("AccentDim") or Theme:Get("SurfaceActive")
        })
    end))

    local releaseConn = group:AddConnection(btn.MouseButton1Up:Connect(function()
        Animations:TweenFast(btn, { BackgroundColor3 =
            opts.Style == "Primary" and Theme:Get("Accent") or Theme:Get("Surface")
        })
    end))

    local clickConn = group:AddConnection(btn.MouseButton1Click:Connect(function()
        if opts.Callback then
            task.spawn(opts.Callback)
        end
        Events:Fire("Button.Clicked", id)
    end))

    -- Hover
    local hoverConns = Utilities:AddHover(btn,
        opts.Style == "Primary" and Theme:Get("Accent") or Theme:Get("Surface"),
        opts.Style == "Primary" and Theme:Get("AccentDim") or Theme:Get("SurfaceHover")
    )
    for _, c in ipairs(hoverConns) do group:AddConnection(c) end

    local component = { Instance = container, Button = btn, _id = id }

    function component:SetTitle(text)
        lbl.Text = text
    end

    function component:SetEnabled(enabled)
        btn.Active = enabled
        Animations:TweenFast(lbl, { TextColor3 = enabled and Theme:Get("TextPrimary") or Theme:Get("TextDisabled") })
    end

    function component:Destroy()
        group:Destroy()
        container:Destroy()
    end

    return component
end

