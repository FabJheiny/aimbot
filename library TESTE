    gui.Name = "ApexUI_" .. (opts.Title or "Window") .. "_" .. id
    gui.ResetOnSpawn = false
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.IgnoreGuiInset = false

    -- Try CoreGui first, fallback to PlayerGui
    local ok = pcall(function()
        gui.Parent = game:GetService("CoreGui")
    end)
    if not ok then
        gui.Parent = PlayerGui
    end

    -- Main window frame
    local initX = opts.X or math.floor((safe.Width - W) / 2)
    local initY = opts.Y or math.floor((safe.Height - H) / 3)

    local win = Utilities:Frame({
        Color = Theme:Get("Background"),
        Size = UDim2.new(0, W, 0, H),
        Position = UDim2.new(0, initX, 0, initY),
        Clip = true,
        Parent = gui,
        Name = "Window",
    })
    Utilities:Corner(win, Theme:Get("RadiusLarge"))
    Utilities:Stroke(win, Theme:Get("Border"), 1)

    -- ── HEADER ──
    local header = Utilities:Frame({
        Color = Theme:Get("BackgroundAlt"),
        Size = UDim2.new(1, 0, 0, HEADER_H),
        Parent = win,
        Name = "Header",
    })

    local titleLbl = Utilities:Label({
        Text = opts.Title or "Window",
        Color = Theme:Get("TextPrimary"),
        Font = Theme:Get("FontSemibold"),
        Size = Theme:Get("SizeTitle"),
        FrameSize = UDim2.new(1, -80, 1, 0),
        Position = UDim2.new(0, Theme:Get("Padding"), 0, 0),
        Parent = header,
    })

    local subtitleLbl = Utilities:Label({
        Text = opts.Subtitle or "",
        Color = Theme:Get("TextDisabled"),
        Font = Theme:Get("FontBody"),
        Size = Theme:Get("SizeCaption"),
        FrameSize = UDim2.new(1, -80, 0, 14),
        Position = UDim2.new(0, Theme:Get("Padding"), 1, -16),
        Parent = header,
    })

    -- Close button
    local closeBtn = Utilities:Button({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Text = "✕",
        TextColor = Theme:Get("TextSecondary"),
        Font = Theme:Get("FontBody"),
        TextSize = 13,
        Size = UDim2.new(0, 32, 0, 32),
        Position = UDim2.new(1, -40, 0.5, -16),
        Parent = header,
    })
    Utilities:Corner(closeBtn, Theme:Get("RadiusSmall"))

    local hConns = Utilities:AddHover(closeBtn, Color3.fromRGB(0,0,0), Theme:Get("SurfaceHover"))
    for _, c in ipairs(hConns) do group:AddConnection(c) end

    local isVisible = true

    group:AddConnection(closeBtn.MouseButton1Click:Connect(function()
        isVisible = false
        Animations:TweenMedium(win, { Size = UDim2.new(0, W, 0, 0) }).Completed:Connect(function()
            win.Visible = false
        end)
        Events:Fire("Window.Closed", id)
    end))

    -- Minimize button
    local minBtn = Utilities:Button({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Text = "─",
        TextColor = Theme:Get("TextSecondary"),
        Font = Theme:Get("FontBody"),
        TextSize = 13,
        Size = UDim2.new(0, 32, 0, 32),
        Position = UDim2.new(1, -76, 0.5, -16),
        Parent = header,
    })
    Utilities:Corner(minBtn, Theme:Get("RadiusSmall"))

    local hConns2 = Utilities:AddHover(minBtn, Color3.fromRGB(0,0,0), Theme:Get("SurfaceHover"))
    for _, c in ipairs(hConns2) do group:AddConnection(c) end

    local minimized = false
    local savedH = H

    group:AddConnection(minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            savedH = win.AbsoluteSize.Y
            Animations:TweenMedium(win, { Size = UDim2.new(0, W, 0, HEADER_H) })
        else
            Animations:TweenMedium(win, { Size = UDim2.new(0, W, 0, savedH) })
        end
    end))

    -- ── DRAG  (hold 0.5s, cancel on scroll) ──
    local dragHolding = false
    local dragActive = false
    local dragStart, winStart
    local holdTask = nil
    local scrollDetected = false

    group:AddConnection(header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragHolding = true
            scrollDetected = false
            dragStart = input.Position
            winStart = win.Position

            holdTask = task.delay(0.5, function()
                if dragHolding and not scrollDetected then
                    dragActive = true
                end
            end)
        end
    end))

    group:AddConnection(UserInputService.InputChanged:Connect(function(input)
        if dragActive and (input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            -- Detect scroll gesture (large vertical movement without confirmed drag)
            if not dragActive and math.abs(delta.Y) > math.abs(delta.X) * 1.5 then
                scrollDetected = true
                dragHolding = false
                return
            end
            local newPos = UDim2.new(
                winStart.X.Scale,
                winStart.X.Offset + delta.X,
                winStart.Y.Scale,
                winStart.Y.Offset + delta.Y
            )
            -- Clamp to screen
            local sa = Utilities:GetSafeArea()
            local clampedX = math.clamp(newPos.X.Offset, 0, sa.Width  - W)
            local clampedY = math.clamp(newPos.Y.Offset, sa.InsetTop, sa.Height - HEADER_H)
            win.Position = UDim2.new(0, clampedX, 0, clampedY)
        end
    end))

    group:AddConnection(UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragHolding = false
            dragActive = false
            if holdTask then
                pcall(function() task.cancel(holdTask) end)
                holdTask = nil
            end
        end
    end))

    -- ── TAB BAR ──
    local tabBar = Utilities:Frame({
        Color = Theme:Get("BackgroundAlt"),
        Size = UDim2.new(1, 0, 0, TAB_H),
        Position = UDim2.new(0, 0, 0, HEADER_H),
        Parent = win,
        Name = "TabBar",
    })

    local tabScroll = Instance.new("ScrollingFrame")
    tabScroll.BackgroundTransparency = 1
    tabScroll.BorderSizePixel = 0
    tabScroll.Size = UDim2.new(1, 0, 1, 0)
    tabScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabScroll.AutomaticCanvasSize = Enum.AutomaticSize.X
    tabScroll.ScrollBarThickness = 0
    tabScroll.ScrollingDirection = Enum.ScrollingDirection.X
    tabScroll.Parent = tabBar

    local tabLayout = Utilities:ListLayout(tabScroll, Enum.FillDirection.Horizontal, 0)
    tabLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    -- Bottom border on tab bar
    local tabBorder = Utilities:Frame({
        Color = Theme:Get("Border"),
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -1),
        Parent = tabBar,
    })

    -- ── CONTENT AREA ──
    local contentArea = Utilities:Frame({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Size = UDim2.new(1, 0, 1, -(HEADER_H + TAB_H)),
        Position = UDim2.new(0, 0, 0, HEADER_H + TAB_H),
        Parent = win,
        Clip = true,
        Name = "Content",
    })

    local tabs = {}
    local activeTab = nil
    local activeBtnRef = nil

    local function selectTab(tab, btnRef)
        if activeTab then
            activeTab:Hide()
        end
        if activeBtnRef then
            Animations:TweenFast(activeBtnRef, { BackgroundColor3 = Color3.fromRGB(0,0,0) })
            for _, c in ipairs(activeBtnRef:GetChildren()) do
                if c:IsA("TextLabel") then
                    Animations:TweenFast(c, { TextColor3 = Theme:Get("TextSecondary") })
                end
                if c:IsA("Frame") then
                    c.Visible = false
                end
            end
        end
        tab:Show()
        activeTab = tab
        activeBtnRef = btnRef

        Animations:TweenFast(btnRef, { BackgroundColor3 = Theme:Get("SurfaceActive") })
        for _, c in ipairs(btnRef:GetChildren()) do
            if c:IsA("TextLabel") then
                Animations:TweenFast(c, { TextColor3 = Theme:Get("TextPrimary") })
            end
            if c:IsA("Frame") then
                c.Visible = true
            end
        end
        Events:Fire("Tab.Selected", tab._name)
    end

    local window = {
        Instance = win,
        GUI = gui,
        _id = id,
        _group = group,
        _tabs = tabs,
    }

    function window:AddTab(name, icon)
        local tab = createTab(name, contentArea)
        table.insert(tabs, tab)

        -- Tab button
        local tabBtn = Utilities:Button({
            Color = Color3.fromRGB(0,0,0),
            Transparency = 0,
            Text = "",
            Size = UDim2.new(0, 0, 1, 0),
            Parent = tabScroll,
        })
        tabBtn.AutomaticSize = Enum.AutomaticSize.X
        tabBtn.ClipsDescendants = false

        local tabLbl = Utilities:Label({
            Text = name,
            Color = Theme:Get("TextSecondary"),
            Font = Theme:Get("FontBody"),
            Size = Theme:Get("SizeSmall"),
            XAlign = Enum.TextXAlignment.Center,
            FrameSize = UDim2.new(0, 0, 1, -2),
            Parent = tabBtn,
        })
        tabLbl.AutomaticSize = Enum.AutomaticSize.X
        Utilities:Padding(tabLbl, 0, 14, 0, 14)

        -- Active indicator bar
        local indicator = Utilities:Frame({
            Color = Theme:Get("Accent"),
            Size = UDim2.new(1, -16, 0, 2),
            Position = UDim2.new(0, 8, 1, -2),
            Parent = tabBtn,
        })
        Utilities:Corner(indicator, 1)
        indicator.Visible = false

        tabBtn.MouseButton1Click:Connect(function()
            selectTab(tab, tabBtn)
        end)

        -- Select first tab automatically
        if #tabs == 1 then
            task.defer(function()
                selectTab(tab, tabBtn)
            end)
        end

        return tab
    end

    function window:Toggle()
        if win.Visible then
            isVisible = false
            Animations:TweenMedium(win, { Size = UDim2.new(0, W, 0, 0) }).Completed:Connect(function()
                win.Visible = false
            end)
            Events:Fire("Window.Closed", id)
        else
            win.Visible = true
            isVisible = true
            Animations:TweenMedium(win, { Size = UDim2.new(0, W, 0, savedH) })
            Events:Fire("Window.Opened", id)
        end
    end

    function window:SetTitle(text)
        titleLbl.Text = text
    end

    function window:SetSubtitle(text)
        subtitleLbl.Text = text
    end

    function window:Notify(o)
        NotificationQueue:Push(o)
    end

    function window:Dialog(o)
        return Components.Dialog(o)
    end

    function window:Destroy()
        group:Destroy()
        gui:Destroy()
    end

    function window:SaveConfig(name)
        local data = {}
        -- Collect all component values from tabs
        -- (Components store state in State objects; Config saves positions)
        data.Position = { X = win.Position.X.Offset, Y = win.Position.Y.Offset }
        data.Minimized = minimized
        Config:Save(name or opts.Title or "default", data)
    end

    function window:LoadConfig(name)
        local data = Config:Load(name or opts.Title or "default")
        if not data then return end
        if data.Position then
            win.Position = UDim2.new(0, data.Position.X, 0, data.Position.Y)
        end
        if data.Minimized then
            minimized = data.Minimized
        end
        Events:Fire("Config.Loaded", name)
    end

    Events:Fire("Window.Opened", id)
    return window
end

-- ============================================================
-- LIBRARY  (Public API)
-- ============================================================
local Library = {}
Library._version = "1.0.0"
Library._windows = {}
Library._theme = Theme

-- Create a new window
function Library:CreateWindow(opts)
    local win = createWindow(self, opts)
    table.insert(self._windows, win)
    return win
end

-- Notification shortcut
function Library:Notify(opts)
    NotificationQueue:Push(opts)
end

-- Dialog shortcut
function Library:Dialog(opts)
    return Components.Dialog(opts)
end

-- FloatingButton shortcut
function Library:FloatingButton(opts)
    return Components.FloatingButton(opts)
end

-- Theme API
function Library:SetTheme(overrides)
    Theme:Set(overrides)
    Events:Fire("Theme.Changed", Theme.Data)
end

function Library:GetTheme()
    return Utilities:DeepCopy(Theme.Data)
end

-- Global save (all windows)
function Library:SaveConfig(name)
    for _, win in ipairs(self._windows) do
        win:SaveConfig(name)
    end
end

function Library:LoadConfig(name)
    for _, win in ipairs(self._windows) do
        win:LoadConfig(name)
    end
end

-- Listen to library events
function Library:OnEvent(name, fn)
    return Events:Connect(name, fn)
end

-- Destroy everything
function Library:Destroy()
    for _, win in ipairs(self._windows) do
        pcall(function() win:Destroy() end)
    end
    self._windows = {}
    Cleanup:DestroyAll()
    Animations:CancelAll()

    -- Clean up notification/dialog GUIs
    for _, name in ipairs({"ApexUI_Notifications", "ApexUI_Dialogs", "ApexUI_FAB"}) do
        local g = PlayerGui:FindFirstChild(name)
        if g then g:Destroy() end
        local cg = pcall(function()
            local c = game:GetService("CoreGui"):FindFirstChild(name)
            if c then c:Destroy() end
        end)
    end
end

-- ============================================================
-- RETURN
-- ============================================================
return Library
