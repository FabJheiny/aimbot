        content.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y)
        container.Size = UDim2.new(1, 0, 0, 28 + layout.AbsoluteContentSize.Y + 4)
    end)

    local section = { Instance = container, _id = id }

    local function addComponent(constructor, opts2)
        local comp = constructor(content, opts2)
        return comp
    end

    function section:AddToggle(o)      return addComponent(Components.Toggle, o) end
    function section:AddSlider(o)      return addComponent(Components.Slider, o) end
