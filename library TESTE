function Components.Label(parent, opts)
    opts = opts or {}
    local container = Utilities:Frame({
        Color = Color3.fromRGB(0,0,0),
        Transparency = 1,
        Size = UDim2.new(1, 0, 0, 32),
        Parent = parent,
