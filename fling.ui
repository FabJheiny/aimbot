-- Botões de ação (estilo minimalista)
local function createStyledButton(text, position, size, textColor)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Position = position
    btn.Size = size
    btn.Text = text
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 11
    btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    btn.TextColor3 = textColor or Color3.fromRGB(255, 255, 255)
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    return btn
end

local StartButton = createStyledButton(
    "START",
    UDim2.new(0, 10, 0, 250),
    UDim2.new(0.5, -15, 0, 30),
    Color3.fromRGB(0, 255, 100)
)
local StopButton = createStyledButton(
