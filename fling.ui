-- Variáveis de controle
local SelectedTargets = {}
local PlayerEntries = {}   -- mapeia player.Name -> TextButton (linha clicável)
local FlingActive = false
getgenv().OldPos = nil
getgenv().FPDH = workspace.FallenPartsDestroyHeight

-- Controle de minimização
local minimized = false
local fullHeight = 320
local miniHeight = 24   -- apenas a barra superior visível

-- Conjunto de elementos que serão escondidos quando minimizado
local contentElements = {
    StatusLabel,
    PlayerListFrame,
    StartButton,
    StopButton,
    SelectAllButton,
    DeselectAllButton
}

MinimizeButton.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        MainFrame.Size = UDim2.new(0, 200, 0, miniHeight)
        for _, el in ipairs(contentElements) do
            el.Visible = false
        end
        MinimizeButton.Text = "+"
    else
        MainFrame.Size = UDim2.new(0, 200, 0, fullHeight)
        for _, el in ipairs(contentElements) do
            el.Visible = true
        end
        MinimizeButton.Text = "-"
    end
end)

-- Atualiza o texto do status
local function UpdateStatus()
    local count = 0
    for _ in pairs(SelectedTargets) do count = count + 1 end
    if FlingActive then
        StatusLabel.Text = "Flinging " .. count .. " target(s)"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    else
        StatusLabel.Text = count .. " target(s) selected"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end

-- Atualiza a lista visual de jogadores
local function RefreshPlayerList()
    -- Limpa entradas anteriores
    for _, child in pairs(PlayerScrollFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    PlayerEntries = {}

    local playerList = Players:GetPlayers()
    table.sort(playerList, function(a, b) return a.Name:lower() < b.Name:lower() end)

    local yPos = 2
    for _, otherPlayer in ipairs(playerList) do
        if otherPlayer ~= Player then
            local isSelected = SelectedTargets[otherPlayer.Name] ~= nil

            -- Linha clicável que representa o jogador
            local row = Instance.new("TextButton", PlayerScrollFrame)
            row.Size = UDim2.new(1, -4, 0, 26)
            row.Position = UDim2.new(0, 2, 0, yPos)
            row.BackgroundTransparency = 1
            row.Text = (isSelected and "✓  " or "     ") .. otherPlayer.Name
            row.TextColor3 = isSelected and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 255, 255)
            row.TextSize = 12
            row.Font = Enum.Font.SourceSans
            row.TextXAlignment = Enum.TextXAlignment.Left
            row.BorderSizePixel = 0
            row.AutoButtonColor = false

            row.MouseButton1Click:Connect(function()
                if SelectedTargets[otherPlayer.Name] then
                    SelectedTargets[otherPlayer.Name] = nil
                else
                    SelectedTargets[otherPlayer.Name] = otherPlayer
                end
                RefreshPlayerList()
                UpdateStatus()
            end)

            PlayerEntries[otherPlayer.Name] = row
            yPos = yPos + 28
        end
    end

    PlayerScrollFrame.CanvasSize = UDim2.new(0, 0, 0, yPos + 4)
end

-- Seleciona/deseleciona todos
local function ToggleAll(select)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Player then
            if select then
                SelectedTargets[p.Name] = p
            else
                SelectedTargets[p.Name] = nil
            end
        end
    end
    RefreshPlayerList()
    UpdateStatus()
end

-- Notificação simples (opcional)
local function Message(title, text, duration)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = title,
        Text = text,
        Duration = duration or 3
    })
end

-- Lógica de fling (mantida igual, apenas renomeada)
local function SkidFling(TargetPlayer)
    local Character = Player.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    local RootPart = Humanoid and Humanoid.RootPart
    local TCharacter = TargetPlayer.Character
    if not TCharacter then return end

    local THumanoid, TRootPart, THead, Accessory, Handle
    if TCharacter:FindFirstChildOfClass("Humanoid") then
        THumanoid = TCharacter:FindFirstChildOfClass("Humanoid")
    end
    if THumanoid and THumanoid.RootPart then
        TRootPart = THumanoid.RootPart
    end
    if TCharacter:FindFirstChild("Head") then
        THead = TCharacter.Head
    end
    if TCharacter:FindFirstChildOfClass("Accessory") then
        Accessory = TCharacter:FindFirstChildOfClass("Accessory")
    end
    if Accessory and Accessory:FindFirstChild("Handle") then
        Handle = Accessory.Handle
    end

    if Character and Humanoid and RootPart then
        if RootPart.Velocity.Magnitude < 50 then
            getgenv().OldPos = RootPart.CFrame
        end

        if THumanoid and THumanoid.Sit then
            return Message("Error", TargetPlayer.Name .. " is sitting")
        end

        if THead then
            workspace.CurrentCamera.CameraSubject = THead
        elseif Handle then
            workspace.CurrentCamera.CameraSubject = Handle
        elseif THumanoid and TRootPart then
            workspace.CurrentCamera.CameraSubject = THumanoid
        end

        if not TCharacter:FindFirstChildWhichIsA("BasePart") then
            return
        end

        local FPos = function(BasePart, Pos, Ang)
            RootPart.CFrame = CFrame.new(BasePart.Position) * Pos * Ang
            Character:SetPrimaryPartCFrame(CFrame.new(BasePart.Position) * Pos * Ang)
            RootPart.Velocity = Vector3.new(9e7, 9e7 * 10, 9e7)
            RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
        end

        local SFBasePart = function(BasePart)
            local TimeToWait = 2
            local Time = tick()
            local Angle = 0
            repeat
                if RootPart and THumanoid then
                    if BasePart.Velocity.Magnitude < 50 then
                        Angle = Angle + 100
                        FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle),0 ,0))
                        task.wait()
                        FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                        task.wait()
                        FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle),0 ,0))
                        task.wait()
                        FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                        task.wait()
                        FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection, CFrame.Angles(math.rad(Angle),0 ,0))
                        task.wait()
                        FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection, CFrame.Angles(math.rad(Angle), 0, 0))
                        task.wait()
                    else
                        FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                        task.wait()
                        FPos(BasePart, CFrame.new(0, -1.5, -THumanoid.WalkSpeed), CFrame.Angles(0, 0, 0))
                        task.wait()
                        FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                        task.wait()
                        FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90), 0, 0))
                        task.wait()
                        FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                        task.wait()
                        FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90), 0, 0))
                        task.wait()
                        FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                        task.wait()
                    end
                end
            until Time + TimeToWait < tick() or not FlingActive
        end

        workspace.FallenPartsDestroyHeight = 0/0

        local BV = Instance.new("BodyVelocity")
        BV.Parent = RootPart
        BV.Velocity = Vector3.new(0, 0, 0)
        BV.MaxForce = Vector3.new(9e9, 9e9, 9e9)

        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)

        if TRootPart then
            SFBasePart(TRootPart)
        elseif THead then
            SFBasePart(THead)
        elseif Handle then
            SFBasePart(Handle)
        else
            return Message("Error", TargetPlayer.Name .. " has no valid parts")
        end

        BV:Destroy()
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
        workspace.CurrentCamera.CameraSubject = Humanoid

        if getgenv().OldPos then
            repeat
                RootPart.CFrame = getgenv().OldPos * CFrame.new(0, .5, 0)
                Character:SetPrimaryPartCFrame(getgenv().OldPos * CFrame.new(0, .5, 0))
                Humanoid:ChangeState("GettingUp")
                for _, part in pairs(Character:GetChildren()) do
                    if part:IsA("BasePart") then
                        part.Velocity, part.RotVelocity = Vector3.new(), Vector3.new()
                    end
                end
                task.wait()
            until (RootPart.Position - getgenv().OldPos.p).Magnitude < 25
            workspace.FallenPartsDestroyHeight = getgenv().FPDH
        end
    else
        return Message("Error", "Your character is not ready")
    end
end

-- Iniciar o loop de fling
local function StartFling()
    if FlingActive then return end
    local count = 0
    for _ in pairs(SelectedTargets) do count = count + 1 end
    if count == 0 then
        StatusLabel.Text = "No targets selected!"
        task.wait(1)
        UpdateStatus()
        return
    end

    FlingActive = true
    UpdateStatus()
    Message("Started", "Flinging " .. count .. " targets")

    task.spawn(function()
        while FlingActive do
            local validTargets = {}
            -- Copia alvos válidos
            for name, player in pairs(SelectedTargets) do
                if player and player.Parent then
                    validTargets[name] = player
                else
                    SelectedTargets[name] = nil
                end
            end

            for _, player in pairs(validTargets) do
                if not FlingActive then break end
                SkidFling(player)
                task.wait(0.1)
            end

            RefreshPlayerList()
            UpdateStatus()
            task.wait(0.5)
        end
    end)
end

-- Parar o fling
local function StopFling()
    if not FlingActive then return end
    FlingActive = false
    UpdateStatus()
    Message("Stopped", "Fling has been stopped")
end

-- Conexões dos botões
StartButton.MouseButton1Click:Connect(StartFling)
StopButton.MouseButton1Click:Connect(StopFling)
SelectAllButton.MouseButton1Click:Connect(function() ToggleAll(true) end)
DeselectAllButton.MouseButton1Click:Connect(function() ToggleAll(false) end)

-- Atualiza lista quando jogadores entram/saem
Players.PlayerAdded:Connect(RefreshPlayerList)
Players.PlayerRemoving:Connect(function(player)
    if SelectedTargets[player.Name] then
        SelectedTargets[player.Name] = nil
    end
    RefreshPlayerList()
    UpdateStatus()
end)

-- Inicialização
RefreshPlayerList()
UpdateStatus()
Message("Loaded", "Multi Fling GUI ready!")
