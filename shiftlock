local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "MobileShiftlockGUI"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = Player:WaitForChild("PlayerGui")

local ToggleButton = Instance.new("ImageButton")
ToggleButton.BackgroundTransparency = 1
ToggleButton.Size = UDim2.new(0, 40, 0, 40)
ToggleButton.Position = UDim2.new(0.85, -20, 0.5, -20)
ToggleButton.Image = "rbxasset://textures/ui/mouseLock_off@2x.png"
ToggleButton.Parent = ScreenGui

-- Drag
local dragging, dragInput, dragStart, startPos

ToggleButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = ToggleButton.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

ToggleButton.InputChanged:Connect(function(input)
    local t = input.UserInputType
    if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        ToggleButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Shiftlock
local shiftLockEnabled = false
local ZERO_OFFSET = Vector3.new(0, 0, 0)
local IMG_ON = "rbxasset://textures/ui/mouseLock_on@2x.png"
local IMG_OFF = "rbxasset://textures/ui/mouseLock_off@2x.png"

local function getHumanoid()
    return Player.Character and Player.Character:FindFirstChild("Humanoid")
end

local function getRootPart()
    return Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
end

ToggleButton.Activated:Connect(function()
    shiftLockEnabled = not shiftLockEnabled
    local humanoid = getHumanoid()
    if humanoid then
        humanoid.AutoRotate = not shiftLockEnabled
        if not shiftLockEnabled then
            humanoid.CameraOffset = ZERO_OFFSET
        end
    end
    ToggleButton.Image = shiftLockEnabled and IMG_ON or IMG_OFF
end)

RunService.RenderStepped:Connect(function()
    if not shiftLockEnabled then return end
    local rootPart = getRootPart()
    if not rootPart then return end

    local look = Camera.CFrame.LookVector
    rootPart.CFrame = CFrame.new(rootPart.Position, rootPart.Position + Vector3.new(look.X, 0, look.Z))
end)
