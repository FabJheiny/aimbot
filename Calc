-- Variáveis
local current = "0"

local function atualizar(valor)
    display.Text = valor
end

local function adicionar(valor)
    if current == "0" then
        current = valor
    else
        current = current .. valor
    end
    atualizar(current)
end

local function calcular()
    local expr = current
    expr = expr:gsub("×", "*"):gsub("÷", "/")

    local success, result = pcall(function()
        return loadstring("return " .. expr)()
    end)

    if success then
        current = tostring(result)
    else
        current = "Erro"
    end

    atualizar(current)
end

local function deletarUltimo()
    if #current <= 1 or current == "Erro" then
        current = "0"
    else
        current = current:sub(1, -2)
    end
    atualizar(current)
end

local BTN   = 40
local STEP  = 42
local STARTX = 5
local STARTY = 2

local function criarBotao(texto, x, y, cor, textoCor, fontSize)
    local btn = Instance.new("TextButton", btnContainer)
    btn.Size = UDim2.new(0, BTN, 0, BTN)
    btn.Position = UDim2.new(0, STARTX + (x * STEP), 0, STARTY + (y * STEP))
    btn.Text = texto
    btn.TextSize = fontSize or 12
    btn.Font = Enum.Font.Gotham
    btn.BackgroundColor3 = cor or Color3.fromRGB(30,30,30)
    btn.TextColor3 = textoCor or Color3.fromRGB(220,220,220)

    local corner = Instance.new("UICorner", btn)
    corner.CornerRadius = UDim.new(0, 7)

    btn.MouseButton1Click:Connect(function()
        if texto == "AC" then
            current = "0"
            atualizar(current)
        elseif texto == "DEL" then
            deletarUltimo()
        elseif texto == "=" then
            calcular()
        elseif texto == "%" then
            local num = tonumber(current)
            if num then current = tostring(num / 100) end
            atualizar(current)
        elseif texto == "+" or texto == "-" or texto == "×" or texto == "÷" then
            local ultimo = current:sub(-1)
            if ultimo ~= "+" and ultimo ~= "-" and ultimo ~= "×" and ultimo ~= "÷" then
                current = current .. texto
                atualizar(current)
            end
        elseif texto == "." then
            local segmento = current:match("[%d%.]+$") or ""
            if not segmento:find("%.") then
                current = current .. "."
                atualizar(current)
            end
        else
            adicionar(texto)
        end
    end)
end

local layout = {
    {"AC",  "(",  ")",  "÷"},
    {"7",   "8",  "9",  "×"},
    {"4",   "5",  "6",  "-"},
    {"1",   "2",  "3",  "+"},
    {"0",   ".",  "%",  "="},
    {"DEL", "",   "",   ""}
}

for y, linha in ipairs(layout) do
    for x, texto in ipairs(linha) do
        if texto == "" then continue end

        local cor      = Color3.fromRGB(30,30,30)
        local textoCor = Color3.fromRGB(220,220,220)
        local fontSize = 12

        if texto == "AC" then
            cor = Color3.fromRGB(45,45,45)
            textoCor = Color3.fromRGB(255,100,100)
        elseif texto == "DEL" then
            cor = Color3.fromRGB(45,45,45)
            textoCor = Color3.fromRGB(255,100,100)
        elseif texto == "=" then
            cor = Color3.fromRGB(240,200,80)
            textoCor = Color3.fromRGB(20,20,20)
            fontSize = 16
        elseif texto == "+" or texto == "-" or texto == "×" or texto == "÷" then
            cor = Color3.fromRGB(36,36,36)
            textoCor = Color3.fromRGB(210,210,210)
            fontSize = 17
        elseif texto == "(" or texto == ")" or texto == "%" then
            textoCor = Color3.fromRGB(130,130,130)
        end

        criarBotao(texto, x-1, y-1, cor, textoCor, fontSize)
    end
end
