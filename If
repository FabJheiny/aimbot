local function makeRow(cmd, catColor)
    local ROW_H = 26
    local row = newInst("Frame", {
        Size             = UDim2.new(1, 0, 0, ROW_H),
        BackgroundColor3 = T.bg,
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
    })

    newInst("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = 0.94,
        BorderSizePixel  = 0,
        Parent           = row,
    })

    local dot = newInst("Frame", {
        Size             = UDim2.new(0, 5, 0, 5),
        Position         = UDim2.new(0, 0, 0.5, -2),
        BackgroundColor3 = catColor,
        BackgroundTransparency = 0.5,
        BorderSizePixel  = 0,
        Parent           = row,
    })
    uiCorner(99, dot)

    local nameLabel = newInst("TextLabel", {
        Text             = cmd.n,
        Font             = Enum.Font.GothamBold,
        TextSize         = 11,
        TextColor3       = Color3.fromRGB(226,232,240),
        BackgroundTransparency = 1,
        Size             = UDim2.new(0, 0, 1, 0),
        Position         = UDim2.new(0, 12, 0, 0),
        TextXAlignment   = Enum.TextXAlignment.Left,
        AutomaticSize    = Enum.AutomaticSize.X,
        Parent           = row,
    })

    local nameWidth = 12 + #cmd.n * 7
    if cmd.a then
        newInst("TextLabel", {
            Text           = " "..cmd.a,
            Font           = Enum.Font.Code,
            TextSize       = 10,
            TextColor3     = T.textArg,
            BackgroundTransparency = 1,
            Size           = UDim2.new(0, 0, 1, 0),
            Position       = UDim2.new(0, nameWidth, 0, 0),
            TextXAlignment = Enum.TextXAlignment.Left,
            AutomaticSize  = Enum.AutomaticSize.X,
            Parent         = row,
        })
        nameWidth = nameWidth + #(" "..cmd.a)*6
    end

    newInst("TextLabel", {
        Text           = " — ",
        Font           = Enum.Font.Code,
        TextSize       = 10,
        TextColor3     = Color3.fromRGB(45,55,72),
        BackgroundTransparency = 1,
        Size           = UDim2.new(0, 24, 1, 0),
        Position       = UDim2.new(0, nameWidth, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent         = row,
    })

    local descX = nameWidth + 24
    newInst("TextLabel", {
        Text           = truncate(cmd.d, 42),
        Font           = Enum.Font.Code,
        TextSize       = 10,
        TextColor3     = Color3.fromRGB(107,114,128),
        BackgroundTransparency = 1,
        Size           = UDim2.new(1, -(descX+80), 1, 0),
        Position       = UDim2.new(0, descX, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate   = Enum.TextTruncate.AtEnd,
        Parent         = row,
    })

    if cmd.undo then
        newInst("TextLabel", {
            Text           = "↩"..cmd.undo,
            Font           = Enum.Font.Code,
            TextSize       = 9,
            TextColor3     = T.green,
            BackgroundTransparency = 1,
            Size           = UDim2.new(0, 75, 1, 0),
            Position       = UDim2.new(1, -76, 0, 0),
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent         = row,
        })
    elseif cmd.toggle then
        newInst("TextLabel", {
            Text           = "on/off",
            Font           = Enum.Font.Code,
            TextSize       = 9,
            TextColor3     = T.green,
            BackgroundTransparency = 1,
            Size           = UDim2.new(0, 50, 1, 0),
            Position       = UDim2.new(1, -51, 0, 0),
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent         = row,
        })
    end

    local hitbox = newInst("TextButton", {
        Text             = "",
        BackgroundColor3 = T.rowHover,
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 1, 0),
        ZIndex           = 10,
        Parent           = row,
    })
    uiCorner(3, hitbox)

    hitbox.MouseEnter:Connect(function()
        tween(hitbox, {BackgroundTransparency=0.7}, 0.1)
        tween(nameLabel, {TextColor3=Color3.fromRGB(255,255,255)}, 0.1)
        tween(dot, {BackgroundTransparency=0}, 0.1)
    end)
    hitbox.MouseLeave:Connect(function()
        tween(hitbox, {BackgroundTransparency=1}, 0.1)
        tween(nameLabel, {TextColor3=Color3.fromRGB(226,232,240)}, 0.1)
        tween(dot, {BackgroundTransparency=0.5}, 0.1)
    end)
    hitbox.MouseButton1Click:Connect(function()
        tween(hitbox, {BackgroundTransparency=0.4}, 0.05)
        task.wait(0.05)
        tween(hitbox, {BackgroundTransparency=1}, 0.1)
        print("[IY] "..cmd.n.." clicked")
    end)

    return row
end

local function makeSection(catKey, cmds)
    local catColor = CAT_COLORS[catKey]
    local label    = CAT_LABELS[catKey]

    local section = newInst("Frame", {
        Size             = UDim2.new(1, 0, 0, 0),
        AutomaticSize    = Enum.AutomaticSize.Y,
        BackgroundColor3 = T.panel,
        BackgroundTransparency = 0.4,
        BorderSizePixel  = 0,
    })
    uiCorner(5, section)
    uiStroke(T.border, 1, section)
    uiPadding(6,6,8,8, section)

    newInst("UIListLayout", {
        Padding   = UDim.new(0,0),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent    = section,
    })

    local header = newInst("Frame", {
        Size             = UDim2.new(1, 0, 0, 22),
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
        LayoutOrder      = 0,
        Parent           = section,
    })

    local bigDot = newInst("Frame", {
        Size             = UDim2.new(0, 6, 0, 6),
        Position         = UDim2.new(0, 0, 0.5, -3),
        BackgroundColor3 = catColor,
        BorderSizePixel  = 0,
        Parent           = header,
    })
    uiCorner(99, bigDot)

    newInst("TextLabel", {
        Text           = label:upper(),
        Font           = Enum.Font.GothamBold,
        TextSize       = 9,
        TextColor3     = catColor,
        BackgroundTransparency = 1,
        Size           = UDim2.new(1, -60, 1, 0),
        Position       = UDim2.new(0, 14, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent         = header,
    })

    newInst("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        BackgroundColor3 = catColor,
        BackgroundTransparency = 0.75,
        BorderSizePixel  = 0,
        LayoutOrder      = 1,
        Parent           = section,
    })

    for i, cmd in ipairs(cmds) do
        local row = makeRow(cmd, catColor)
        row.LayoutOrder = i + 1
        row.Parent = section
    end

    return section
end

function render(cat, query)
    for _, ch in ipairs(ScrollFrame:GetChildren()) do
        if ch:IsA("GuiObject") and ch ~= ScrollLayout then
            ch:Destroy()
        end
    end

    local q    = (query or ""):lower()
    local cats = cat == "all" and CATEGORIES or {cat}
    local order = 0

    for _, catKey in ipairs(cats) do
        local filtered = {}
        for _, cmd in ipairs(COMMANDS) do
            if cmd.c == catKey then
                if q == "" or cmd.n:lower():find(q,1,true) or cmd.d:lower():find(q,1,true) then
                    table.insert(filtered, cmd)
                end
            end
        end
        if #filtered > 0 then
            local sec = makeSection(catKey, filtered)
            sec.LayoutOrder = order
            sec.Parent = ScrollFrame
            order = order + 1
        end
    end

    if order == 0 then
        newInst("TextLabel", {
            Text           = "Nenhum comando encontrado.",
            Font           = Enum.Font.Code,
            TextSize       = 11,
            TextColor3     = T.textDim,
            BackgroundTransparency = 1,
            Size           = UDim2.new(1, 0, 0, 40),
            TextXAlignment = Enum.TextXAlignment.Center,
            LayoutOrder    = 0,
            Parent         = ScrollFrame,
        })
    end
end

SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    render(activeTab, SearchBox.Text)
end)

