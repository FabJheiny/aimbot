local function newInst(cls, props)
    local i = Instance.new(cls)
    for k,v in pairs(props) do
        if k ~= "Parent" then i[k] = v end
    end
    if props.Parent then i.Parent = props.Parent end
    return i
end

local function uiCorner(r, parent)
    return newInst("UICorner", {CornerRadius=UDim.new(0,r), Parent=parent})
end

local function uiPadding(t,b,l,r, parent)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0,t)
    p.PaddingBottom = UDim.new(0,b)
    p.PaddingLeft   = UDim.new(0,l)
    p.PaddingRight  = UDim.new(0,r)
    p.Parent = parent
    return p
end

local function uiStroke(color, thickness, parent)
    return newInst("UIStroke", {Color=color, Thickness=thickness, Parent=parent})
end

local function tween(inst, props, t, style, dir)
    local info = TweenInfo.new(t or 0.15, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out)
    TweenService:Create(inst, info, props):Play()
end

local function truncate(str, maxLen)
    if #str > maxLen then return str:sub(1, maxLen-2).."…" end
    return str
end

