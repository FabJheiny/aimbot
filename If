local ALL_TABS = {"all","servidor","movimento","visual","players","personagem","veiculos"}
local TAB_LABELS = {
    all="Todos", servidor="Servidor", movimento="Movimento",
    visual="Visual", players="Players", personagem="Personagem", veiculos="Veículos"
}
local activeTab = "all"
local tabButtons = {}

local function styleTab(btn, isActive)
    if isActive then
        tween(btn, {BackgroundColor3=Color3.fromRGB(40,15,80), BackgroundTransparency=0, TextColor3=T.accentLight}, 0.12)
        local s = btn:FindFirstChildOfClass("UIStroke")
        if s then tween(s, {Color=T.accentLight}, 0.12) end
    else
        tween(btn, {BackgroundColor3=T.bg, BackgroundTransparency=0.3, TextColor3=T.textDim}, 0.12)
        local s = btn:FindFirstChildOfClass("UIStroke")
        if s then tween(s, {Color=T.border}, 0.12) end
    end
end

for _, cat in ipairs(ALL_TABS) do
    local btn = newInst("TextButton", {
        Text             = TAB_LABELS[cat],
        Font             = Enum.Font.GothamBold,
        TextSize         = 9,
        TextColor3       = cat=="all" and T.accentLight or T.textDim,
        BackgroundColor3 = cat=="all" and Color3.fromRGB(40,15,80) or T.bg,
        BackgroundTransparency = cat=="all" and 0 or 0.3,
        BorderSizePixel  = 0,
        Size             = UDim2.new(0, 0, 0, 24),
        AutomaticSize    = Enum.AutomaticSize.X,
        Parent           = ToolBar,
    })
    uiCorner(4, btn)
    uiStroke(cat=="all" and T.accentLight or T.border, 1, btn)
    uiPadding(0,0,7,7, btn)
    tabButtons[cat] = btn

    btn.MouseEnter:Connect(function()
        if activeTab ~= cat then tween(btn, {TextColor3=T.text}, 0.1) end
    end)
    btn.MouseLeave:Connect(function()
        if activeTab ~= cat then tween(btn, {TextColor3=T.textDim}, 0.1) end
    end)
    btn.MouseButton1Click:Connect(function()
        activeTab = cat
        for c, b in pairs(tabButtons) do styleTab(b, c == cat) end
        render(cat, SearchBox.Text:lower())
    end)
end

