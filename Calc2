-- Variáveis
local current = "0"

local function atualizar(valor)
    display.Text = valor
end

local function adicionar(valor)
    if current == "0" then
        current = valor
    else
        current = current .. valor
    end
    atualizar(current)
end

local function calcular()
    local expr = current:gsub("×", "*"):gsub("÷", "/")
    local success, result = pcall(function()
        return loadstring("return " .. expr)()
    end)
    current = success and tostring(result) or "Erro"
    atualizar(current)
end

local function deletarUltimo()
    if #current <= 1 or current == "Erro" then
        current = "0"
    else
        current = current:sub(1, -2)
    end
    atualizar(current)
end

local BTN    = 34
local STEP   = 38
local STARTX = 6
local STARTY  = 4

local function criarBotao(texto, x, y, isOperator, isEqual, isDanger, wide)
    local btn = Instance.new("TextButton", btnContainer)
    local w = wide and (BTN * 2 + (STEP - BTN)) or BTN
    btn.Size = UDim2.new(0, w, 0, BTN)
    btn.Position = UDim2.new(0, STARTX + (x * STEP), 0, STARTY + (y * STEP))
    btn.Text = texto
    btn.Font = Enum.Font.SourceSansBold
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false

    if isEqual then
        btn.BackgroundColor3 = Color3.fromRGB(0, 170, 255) -- ButtonActive do Float
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 15
    elseif isDanger then
        btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        btn.TextColor3 = Color3.fromRGB(255, 80, 80)
        btn.TextSize = 10
    elseif isOperator then
        btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        btn.TextColor3 = Color3.fromRGB(0, 170, 255) -- ButtonActive do Float
        btn.TextSize = 15
    else
        btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 11
    end

    btn.MouseButton1Down:Connect(function()
        if not isEqual then
            btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        end
    end)
    btn.MouseButton1Up:Connect(function()
        btn.BackgroundColor3 = isEqual and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(15, 15, 15)
    end)

    btn.MouseButton1Click:Connect(function()
        if texto == "AC" then
            current = "0"
            atualizar(current)
        elseif texto == "DEL" then
            deletarUltimo()
        elseif texto == "=" then
            calcular()
        elseif texto == "%" then
            local num = tonumber(current)
            if num then current = tostring(num / 100) end
            atualizar(current)
        elseif texto == "+" or texto == "-" or texto == "×" or texto == "÷" then
            local ultimo = current:sub(-1)
            if ultimo ~= "+" and ultimo ~= "-" and ultimo ~= "×" and ultimo ~= "÷" then
                current = current .. texto
                atualizar(current)
            end
        elseif texto == "." then
            local segmento = current:match("[%d%.]+$") or ""
            if not segmento:find("%.") then
                current = current .. "."
                atualizar(current)
            end
        else
            adicionar(texto)
        end
    end)
end

local layout = {
    {"AC",  "%",  "DEL", "÷"},
    {"7",   "8",  "9",   "×"},
    {"4",   "5",  "6",   "-"},
    {"1",   "2",  "3",   "+"},
}

for y, linha in ipairs(layout) do
    for x, texto in ipairs(linha) do
        local isOperator = (texto == "+" or texto == "-" or texto == "×" or texto == "÷" or texto == "%")
        local isDanger   = (texto == "AC" or texto == "DEL")
        criarBotao(texto, x-1, y-1, isOperator, false, isDanger, false)
    end
end

criarBotao("0",  0, 4, false, false, false, false)
criarBotao(".",  1, 4, false, false, false, false)
criarBotao("=",  2, 4, false, true,  false, true)
