-- ============================================================
--  NexLib - Modular Framework v1.1.1
--  Arquitetura: Registry + EventBus + State + Loader + UI
-- ============================================================

local NexLib = (function()

local CONFIG = {
    version     = "1.1.1",
    name        = "NexLib",
    httpTimeout = 10,
}

local HttpService      = game:GetService("HttpService")
local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui   = LocalPlayer:WaitForChild("PlayerGui")

local existing = PlayerGui:FindFirstChild("NexLib")
if existing then existing:Destroy() end

local function generateId(name)
    return name:lower():gsub("%s+", "_") .. "_" .. tostring(tick()):sub(-4)
end

local function timestamp()
    local t = os.date("*t")
    return string.format("%02d:%02d:%02d", t.hour, t.min, t.sec)
end

-- EventBus
local EventBus = {}
EventBus._listeners = {}

function EventBus.on(event, callback)
    if not EventBus._listeners[event] then
        EventBus._listeners[event] = {}
    end
    table.insert(EventBus._listeners[event], callback)
end

function EventBus.off(event, callback)
    if not EventBus._listeners[event] then return end
    for i, cb in ipairs(EventBus._listeners[event]) do
        if cb == callback then
            table.remove(EventBus._listeners[event], i)
            break
        end
    end
end

function EventBus.emit(event, data)
    if not EventBus._listeners[event] then return end
    for _, cb in ipairs(EventBus._listeners[event]) do
        task.spawn(cb, data)
    end
end

-- Logger
local Logger = {}

local function log(level, msg)
    local entry = { type = level, msg = msg, time = timestamp() }
    EventBus.emit("log:entry", entry)
    print(string.format("[NexLib][%s][%s] %s", level:upper(), entry.time, msg))
end

function Logger.info(msg)    log("info",    msg) end
function Logger.success(msg) log("success", msg) end
function Logger.warn(msg)    log("warn",    msg) end
function Logger.error(msg)   log("error",   msg) end

-- State
local State = {}
State._data = {
    modules        = {},
    loadStatuses   = {},
    selectedModule = nil,
    searchQuery    = "",
}

function State.get()
    return State._data
end

function State.set(patch)
    for k, v in pairs(patch) do
        State._data[k] = v
    end
    EventBus.emit("state:change", State._data)
end

-- Registry
local Registry = {}

function Registry.Register(descriptor)
    assert(type(descriptor) == "table",                                 "descriptor must be a table")
    assert(type(descriptor.Name) == "string" and #descriptor.Name > 0, "Name required")
    assert(type(descriptor.Load) == "function",                         "Load function required")

    descriptor.Icon        = descriptor.Icon        or "[M]"
    descriptor.Description = descriptor.Description or ""
    descriptor.id          = generateId(descriptor.Name)

    local state = State.get()
    state.modules[descriptor.id]      = descriptor
    state.loadStatuses[descriptor.id] = "idle"

    Logger.info(string.format("Registered: %s", descriptor.Name))
    EventBus.emit("module:registered", descriptor)
    State.set({})

    return descriptor.id
end

function Registry.Unregister(id)
    local state = State.get()
    if not state.modules[id] then
        Logger.warn("Unregister: module not found -> " .. tostring(id))
        return false
    end
    local name = state.modules[id].Name
    state.modules[id]      = nil
    state.loadStatuses[id] = nil
    if state.selectedModule == id then
        State.set({ selectedModule = nil })
    end
    Logger.info("Unregistered: " .. name)
    EventBus.emit("module:unregistered", { id = id })
    State.set({})
    return true
end

function Registry.getAll() return State.get().modules end
function Registry.get(id)  return State.get().modules[id] end

-- Loader
local Loader = {}

function Loader.load(id)
    local state  = State.get()
    local module = state.modules[id]
    if not module then
        Logger.error("Load failed: module not found -> " .. tostring(id))
        return
    end

    if state.loadStatuses[id] == "loading" then
        Logger.warn(module.Name .. " is already loading")
        return
    end

    Logger.info("Loading: " .. module.Name)
    state.loadStatuses[id] = "loading"
    EventBus.emit("module:statusChange", { id = id, status = "loading" })

    task.spawn(function()
        local ok, err = pcall(module.Load)
        if ok then
            state.loadStatuses[id] = "loaded"
            Logger.success(module.Name .. " loaded successfully")
            EventBus.emit("module:statusChange", { id = id, status = "loaded" })
            EventBus.emit("module:loaded",       { id = id, module = module })
        else
            state.loadStatuses[id] = "error"
            Logger.error(module.Name .. " failed: " .. tostring(err))
            EventBus.emit("module:statusChange", { id = id, status = "error" })
            EventBus.emit("module:error",        { id = id, error = err })
        end
        EventBus.emit("state:change", State.get())
    end)
end

function Loader.unload(id)
    local state = State.get()
    if state.loadStatuses[id] == "loaded" then
        state.loadStatuses[id] = "idle"
        EventBus.emit("module:statusChange", { id = id, status = "idle" })
        EventBus.emit("state:change", State.get())
        Logger.info("Unloaded: " .. (state.modules[id] and state.modules[id].Name or id))
    end
end

function Loader.loadAll()
    for id in pairs(State.get().modules) do
        Loader.load(id)
    end
end

-- UI
local UI = {}

local function newInst(class, props, parent)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do inst[k] = v end
    if parent then inst.Parent = parent end
    return inst
end

local function color(hex)
    hex = hex:gsub("#", "")
    return Color3.fromRGB(
        tonumber("0x" .. hex:sub(1, 2)),
        tonumber("0x" .. hex:sub(3, 4)),
        tonumber("0x" .. hex:sub(5, 6))
    )
end

local function tween(inst, goal, t)
    TweenService:Create(inst, TweenInfo.new(t or 0.18, Enum.EasingStyle.Quad), goal):Play()
end

local _gui, _mainFrame, _listFrame, _searchBox, _detailFrame
local _footerLabel, _detailName, _detailDesc, _detailStatus, _runBtn
local _moduleCards = {}

local STATUS_COLORS = {
    idle    = color("606060"),
    loading = color("ffd84f"),
    loaded  = color("4fffb0"),
    error   = color("ff4f4f"),
}

local MIN_W, MIN_H = 280, 360

function UI._makeResizable(frame)
    local handle = newInst("Frame", {
        Name                   = "ResizeHandle",
        Size                   = UDim2.new(0, 16, 0, 16),
        Position               = UDim2.new(1, -16, 1, -16),
        BackgroundColor3       = color("ffffff"),
        BackgroundTransparency = 0.85,
        BorderSizePixel        = 0,
        ZIndex                 = 20,
    }, frame)
    newInst("UICorner", { CornerRadius = UDim.new(0, 4) }, handle)

    newInst("TextLabel", {
        Size                   = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text                   = "#",
        TextColor3             = color("909090"),
        Font                   = Enum.Font.GothamBold,
        TextSize               = 11,
        TextXAlignment         = Enum.TextXAlignment.Center,
        TextYAlignment         = Enum.TextYAlignment.Center,
        ZIndex                 = 21,
    }, handle)

    local resizing   = false
    local startMouse = nil
    local startSize  = nil

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            resizing   = true
            startMouse = Vector2.new(input.Position.X, input.Position.Y)
            startSize  = Vector2.new(frame.AbsoluteSize.X, frame.AbsoluteSize.Y)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if resizing and (
            input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then

            local delta = Vector2.new(input.Position.X, input.Position.Y) - startMouse
            local newW  = math.max(MIN_W, startSize.X + delta.X)
            local newH  = math.max(MIN_H, startSize.Y + delta.Y)

            frame.Size = UDim2.new(0, newW, 0, newH)

            local content = frame:FindFirstChild("Content")
            if content then
                local listScroll = content:FindFirstChild("ListScroll")
                if listScroll then
                    local detailH  = 96
                    local reserved = 34 + 52 + 1 + 36 + 1 + detailH + 36
                    local listH    = math.max(60, newH - reserved)
                    listScroll.Size = UDim2.new(1, 0, 0, listH)

                    local detail = content:FindFirstChild("Detail")
                    if detail then
                        local detailY = 34 + 52 + 1 + 36 + 1 + listH + 8
                        detail.Position = UDim2.new(0, 12, 0, detailY - 34)
                    end
                end
            end
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            resizing = false
        end
    end)
end

