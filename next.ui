function UI._makeDraggable(frame)
    local dragging, startPos, startFramePos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging      = true
            startPos      = input.Position
            startFramePos = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (
            input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - startPos
            frame.Position = UDim2.new(
                startFramePos.X.Scale,
                startFramePos.X.Offset + delta.X,
                startFramePos.Y.Scale,
                startFramePos.Y.Offset + delta.Y
            )
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

function UI._renderList()
    local state = State.get()
    local query = state.searchQuery:lower()

    for _, c in pairs(_moduleCards) do c:Destroy() end
    _moduleCards = {}

    local shown = 0
    for id, m in pairs(state.modules) do
        local qOk = (query == ""
            or m.Name:lower():find(query, 1, true)
            or m.Description:lower():find(query, 1, true))

        if qOk then
            shown = shown + 1
            local status     = state.loadStatuses[id] or "idle"
            local isSelected = state.selectedModule == id

            local card = newInst("Frame", {
                Name                   = "Card_" .. id,
                Size                   = UDim2.new(1, 0, 0, 48),
                BackgroundColor3       = color("ffffff"),
                BackgroundTransparency = isSelected and 0.92 or 0.96,
                BorderSizePixel        = 0,
            }, _listFrame)
            newInst("UICorner", { CornerRadius = UDim.new(0, 8) }, card)
            newInst("UIStroke", {
                Color        = isSelected and color("c8c8c8") or color("ffffff"),
                Thickness    = 1,
                Transparency = isSelected and 0.72 or 0.91,
            }, card)

            local iconBox = newInst("Frame", {
                Size                   = UDim2.new(0, 32, 0, 32),
                Position               = UDim2.new(0, 10, 0.5, -16),
                BackgroundColor3       = color("ffffff"),
                BackgroundTransparency = 0.94,
                BorderSizePixel        = 0,
            }, card)
            newInst("UICorner", { CornerRadius = UDim.new(0, 6) }, iconBox)
            newInst("UIStroke", { Color = color("ffffff"), Thickness = 1, Transparency = 0.91 }, iconBox)
            newInst("TextLabel", {
                Size                   = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text                   = m.Icon,
                TextSize               = 15,
                Font                   = Enum.Font.GothamBold,
            }, iconBox)

            newInst("TextLabel", {
                Size                   = UDim2.new(1, -110, 0, 18),
                Position               = UDim2.new(0, 52, 0, 8),
                BackgroundTransparency = 1,
                Text                   = m.Name,
                TextColor3             = color("e0e0e0"),
                Font                   = Enum.Font.GothamBold,
                TextSize               = 13,
                TextXAlignment         = Enum.TextXAlignment.Left,
                TextTruncate           = Enum.TextTruncate.AtEnd,
            }, card)

            newInst("TextLabel", {
                Size                   = UDim2.new(1, -110, 0, 13),
                Position               = UDim2.new(0, 52, 0, 26),
                BackgroundTransparency = 1,
                Text                   = m.Description,
                TextColor3             = color("606060"),
                Font                   = Enum.Font.Code,
                TextSize               = 10,
                TextXAlignment         = Enum.TextXAlignment.Left,
                TextTruncate           = Enum.TextTruncate.AtEnd,
            }, card)

            local statusBadge = newInst("TextLabel", {
                Size                   = UDim2.new(0, 56, 0, 16),
                Position               = UDim2.new(1, -66, 0.5, -8),
                BackgroundColor3       = STATUS_COLORS[status],
                BackgroundTransparency = 0.87,
                Text                   = status:upper(),
                TextColor3             = STATUS_COLORS[status],
                Font                   = Enum.Font.Code,
                TextSize               = 9,
                TextXAlignment         = Enum.TextXAlignment.Center,
            }, card)
            newInst("UICorner", { CornerRadius = UDim.new(0, 3) }, statusBadge)

            local btn = newInst("TextButton", {
                Size                   = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text                   = "",
                ZIndex                 = 10,
            }, card)
            btn.MouseButton1Click:Connect(function()
                if State.get().selectedModule == id then
                    State.set({ selectedModule = nil })
                else
                    State.set({ selectedModule = id })
                end
            end)

            table.insert(_moduleCards, card)
        end
    end

    if shown == 0 then
        local empty = newInst("TextLabel", {
            Size                   = UDim2.new(1, 0, 0, 36),
            BackgroundTransparency = 1,
            Text                   = "no modules found",
            TextColor3             = color("606060"),
            Font                   = Enum.Font.Code,
            TextSize               = 11,
        }, _listFrame)
        table.insert(_moduleCards, empty)
    end
end

function UI._renderFooter()
    local count = 0
    for _ in pairs(State.get().modules) do count = count + 1 end
    _footerLabel.Text = count .. " module" .. (count ~= 1 and "s" or "") .. " registered"
end

function UI._renderDetail()
    local state = State.get()
    local id    = state.selectedModule

    if not id or not state.modules[id] then
        _detailFrame.Visible = false
        return
    end

    _detailFrame.Visible = true
    local m      = state.modules[id]
    local status = state.loadStatuses[id] or "idle"

    _detailName.Text         = m.Icon .. "  " .. m.Name
    _detailDesc.Text         = m.Description ~= "" and m.Description or "(no description)"
    _detailStatus.Text       = status:upper()
    _detailStatus.TextColor3 = STATUS_COLORS[status]

    if status == "loading" then
        _runBtn.Text       = "LOADING..."
        _runBtn.TextColor3 = color("ffd84f")
    elseif status == "loaded" then
        _runBtn.Text       = "RUN AGAIN"
        _runBtn.TextColor3 = color("4fffb0")
    elseif status == "error" then
        _runBtn.Text       = "ERROR - RETRY"
        _runBtn.TextColor3 = color("ff4f4f")
    else
        _runBtn.Text       = "RUN MODULE"
        _runBtn.TextColor3 = color("e0e0e0")
    end
end

function UI._render()
    if not _gui or not _gui.Parent then return end
    UI._renderList()
    UI._renderFooter()
    UI._renderDetail()
end

function UI.init()
    UI.build()
    EventBus.on("state:change",        UI._render)
    EventBus.on("module:statusChange", UI._render)
    UI._render()
    Logger.success("UI ready")
end

local function _boot()
    Logger.info(string.format("%s v%s booting...", CONFIG.name, CONFIG.version))
    UI.init()
    Logger.success("framework ready - awaiting module registration")
    EventBus.emit("nexlib:ready", { version = CONFIG.version })
end

_boot()

return {
    Register   = function(d)  return Registry.Register(d) end,
    Unregister = function(id) return Registry.Unregister(id) end,
    Load       = function(id) return Loader.load(id) end,
    LoadAll    = function()   return Loader.loadAll() end,
    Unload     = function(id) return Loader.unload(id) end,

    EventBus = EventBus,
    State    = State,
    Logger   = Logger,
    Registry = Registry,
    Loader   = Loader,
    UI       = UI,

    version  = CONFIG.version,
}

end)()

_G.NexLib  = NexLib
_G.Library = NexLib
