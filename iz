local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
repeat wait() until player.Character
local camera = workspace.CurrentCamera
RunService.RenderStepped:Connect(function()
    player.CameraMaxZoomDistance = math.huge
    player.CameraMinZoomDistance = 0.1
    if player.CameraMode == Enum.CameraMode.LockFirstPerson then
        player.CameraMode = Enum.CameraMode.Classic
    end
    if camera.CameraType == Enum.CameraType.Fixed or
       camera.CameraType == Enum.CameraType.Scriptable then
        camera.CameraType = Enum.CameraType.Custom
    end
    if camera.CameraType == Enum.CameraType.Custom then
        local dist = (camera.CFrame.Position - player.Character.HumanoidRootPart.Position).Magnitude
        if dist < 0.5 then
            camera.CFrame = camera.CFrame * CFrame.new(0, 0, 1)
        end
    end
end)
