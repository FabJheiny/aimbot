			Content.Name = "Content"
			Content.BackgroundColor3 = Theme.Background
			Content.BackgroundTransparency = 1
			Content.Size = UDim2.new(1, 0, 1, 0)
			Content.BorderSizePixel = 0
			Content.Parent = Element
			
			local ContentPadding = Instance.new("UIPadding")
			ContentPadding.PaddingLeft = UDim.new(0, 14)
			ContentPadding.PaddingRight = UDim.new(0, 14)
			ContentPadding.PaddingTop = UDim.new(0, 14)
			ContentPadding.PaddingBottom = UDim.new(0, 14)
			ContentPadding.Parent = Content
			
			local Title = Instance.new("TextLabel")
			Title.Name = "Title"
			Title.Text = Cfg.Title or "Title"
			Title.TextSize = 12
			Title.TextColor3 = Theme.TextSecondary
			Title.Font = Enum.Font.GothamBold
			Title.BackgroundTransparency = 1
			Title.Size = UDim2.new(1, 0, 0, 14)
			Title.TextXAlignment = Enum.TextXAlignment.Left
			Title.BorderSizePixel = 0
			Title.Parent = Content
			
			CreateGradient(Title, Color3.fromRGB(255, 96, 144), Color3.fromRGB(160, 128, 255), 90)
			
			local Desc = Instance.new("TextLabel")
			Desc.Name = "Desc"
			Desc.Text = Cfg.Description or ""
			Desc.TextSize = 11
			Desc.TextColor3 = Color3.fromRGB(58, 56, 88)
			Desc.Font = Enum.Font.Gotham
			Desc.BackgroundTransparency = 1
			Desc.Size = UDim2.new(1, 0, 1, -20)
			Desc.Position = UDim2.new(0, 0, 0, 20)
			Desc.TextXAlignment = Enum.TextXAlignment.Left
			Desc.TextYAlignment = Enum.TextYAlignment.Top
			Desc.TextWrapped = true
			Desc.LineHeight = 1.6
			Desc.BorderSizePixel = 0
			Desc.Parent = Content
			
			return Paragraph
		end
		
		return Tab
	end
	
	function Window:SetActive(TabName)
		for _, Tab in pairs(Window.Tabs) do
			if Tab.Name == TabName then
				Tab.TabButton.MouseButton1Click:Fire()
				break
			end
		end
	end
	
	HideBtn.MouseButton1Click:Connect(function()
		if ScreenGui.Enabled then
			TweenValue(WindowWrap, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -(Config.WindowWidth + 4) / 2, 0.5, -(Config.WindowHeight + 4) / 2)})
			task.wait(0.3)
			ScreenGui.Enabled = false
		end
	end)
	
	local DragStart = nil
	local DragOffset = nil
	
	MainWindow.InputBegan:Connect(function(Input, GameProcessed)
		if Input.UserInputType == Enum.UserInputType.MouseButton1 and not GameProcessed then
			if Input.Position.Y < TopBar.AbsolutePosition.Y + TopBar.AbsoluteSize.Y then
				DragStart = Input.Position
				DragOffset = WindowWrap.Position
			end
		end
	end)
	
	UserInputService.InputChanged:Connect(function(Input, GameProcessed)
		if DragStart and Input.UserInputType == Enum.UserInputType.MouseMovement then
			local Delta = Input.Position - DragStart
			WindowWrap.Position = DragOffset + UDim2.new(0, Delta.X, 0, Delta.Y)
		end
	end)
	
	UserInputService.InputEnded:Connect(function(Input, GameProcessed)
		if Input.UserInputType == Enum.UserInputType.MouseButton1 then
			DragStart = nil
		end
	end)
	
	return Window
end

return Library
