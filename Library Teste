			local function UpdateSlider(InputPos, FromInput)
				local Percent = math.clamp((InputPos - TrackBg.AbsolutePosition.X) / TrackBg.AbsoluteSize.X, 0, 1)
				Slider.Value = math.floor(Slider.Min + (Slider.Max - Slider.Min) * Percent + 0.5)
				
				local NewPercent = (Slider.Value - Slider.Min) / (Slider.Max - Slider.Min)
				
				TrackFill.Size = UDim2.new(NewPercent, 0, 1, 0)
				Thumb.Position = UDim2.new(NewPercent, -7.5, 0.5, -7.5)
				ValueLabel.Text = tostring(Slider.Value)
				
				if FromInput then
					Slider.Callback(Slider.Value)
				end
			end
			
			local Dragging = false
			
			Thumb.MouseButton1Down:Connect(function()
				Dragging = true
			end)
			
			UserInputService.InputEnded:Connect(function(Input, GameProcessed)
				if Input.UserInputType == Enum.UserInputType.MouseButton1 then
					Dragging = false
				end
			end)
			
			UserInputService.InputChanged:Connect(function(Input, GameProcessed)
				if Dragging and Input.UserInputType == Enum.UserInputType.MouseMovement then
					UpdateSlider(UserInputService:GetMouseLocation().X, true)
				end
			end)
			
			TrackBg.MouseButton1Click:Connect(function()
				UpdateSlider(UserInputService:GetMouseLocation().X, true)
			end)
			
			UpdateSlider(TrackBg.AbsolutePosition.X + TrackBg.AbsoluteSize.X * 0.72, false)
			
			return Slider
		end
		
