local RB = {
    ColorSequenceKeypoint.new(0,    Color3.fromRGB(255, 60,120)),
    ColorSequenceKeypoint.new(0.14, Color3.fromRGB(255,140,  0)),
    ColorSequenceKeypoint.new(0.28, Color3.fromRGB(255,220,  0)),
    ColorSequenceKeypoint.new(0.42, Color3.fromRGB( 96,255, 96)),
    ColorSequenceKeypoint.new(0.57, Color3.fromRGB(  0,192,255)),
    ColorSequenceKeypoint.new(0.71, Color3.fromRGB( 96, 96,255)),
