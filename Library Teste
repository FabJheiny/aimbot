		local function SelectTab()
			if Window.ActiveTab then
				Window.ActiveTab.Container.Visible = false
				local OldTabButton = Window.ActiveTab.TabButton
				OldTabButton.BackgroundColor3 = Theme.SidebarBg
				
				local OldGlow = OldTabButton:FindFirstChild("TabGlow")
				if OldGlow then
					TweenValue(OldGlow, TweenInfo.new(0.2), {Size = UDim2.new(0, 3, 0, 0)})
				end
				
				local OldText = OldTabButton:FindFirstChild("TabText")
				if OldText then
					OldText.TextColor3 = Color3.fromRGB(58, 56, 88)
				end
				
				local OldDot = OldTabButton:FindFirstChild("TabDot")
				if OldDot then
					OldDot.BackgroundColor3 = Color3.fromRGB(26, 24, 56)
				end
			end
			
			TabButton.BackgroundColor3 = Color3.fromRGB(120, 80, 255)
			TabButton.BackgroundTransparency = 0.9
			
			local Glow = TabButton:FindFirstChild("TabGlow")
			if Glow then
				TweenValue(Glow, TweenInfo.new(0.2), {Size = UDim2.new(0, 3, 0, 18)})
			end
			
			local Text = TabButton:FindFirstChild("TabText")
			if Text then
				Text.TextColor3 = Color3.fromRGB(200, 184, 255)
			end
			
			local Dot = TabButton:FindFirstChild("TabDot")
			if Dot then
				local DotGradient = new("UIGradient", Dot)
				DotGradient.Color = ColorSequence.new({
					ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 96, 144)),
					ColorSequenceKeypoint.new(1, Color3.fromRGB(96, 96, 255))
				})
				Dot.BackgroundColor3 = Color3.new(1, 1, 1)
			end
			
			Container.Visible = true
			Window.ActiveTab = Tab
			TopBarTitle.Text = TabName
		end
		
		local Connection
		Connection = TabButton.MouseButton1Click:Connect(SelectTab)
		
		Tab.TabButton = TabButton
		table.insert(Window.Tabs, Tab)
		
		if #Window.Tabs == 1 then
			SelectTab()
		end
		
