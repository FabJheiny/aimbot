			local ToggleState = Config.Default or false
			local ToggleEnabled = true

			local function SetToggleState(Value)
				ToggleState = Value
				ToggleEnabled = false

				if Value then
					TweenProperty(ToggleKnob, {Position = UDim2.new(0, 21, 0.5, -8)}, Config.TweenSpeed or 0.2)
					ToggleTrack.BackgroundColor3 = Theme.AccentPink
				else
					TweenProperty(ToggleKnob, {Position = UDim2.new(0, 3, 0.5, -8)}, Config.TweenSpeed or 0.2)
					ToggleTrack.BackgroundColor3 = Theme.BorderDark
				end

				task.wait(Config.TweenSpeed or 0.2)
				ToggleEnabled = true

				if Config.Callback then
					Config.Callback(Value)
				end
			end

			if ToggleState then
				ToggleKnob.Position = UDim2.new(0, 21, 0.5, -8)
				ToggleTrack.BackgroundColor3 = Theme.AccentPink
			else
				ToggleKnob.Position = UDim2.new(0, 3, 0.5, -8)
				ToggleTrack.BackgroundColor3 = Theme.BorderDark
				if ToggleTrack:FindFirstChild("UIGradient") then
					ToggleTrack:FindFirstChild("UIGradient"):Destroy()
				end
			end

			ToggleTrack.InputBegan:Connect(function(Input, GameProcessed)
				if GameProcessed then return end
				if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
					if ToggleEnabled then
