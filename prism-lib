local function CreateGradient(Color1, Color2, Rotation)
	local Gradient = Instance.new("UIGradient")
	Gradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color1),
		ColorSequenceKeypoint.new(1, Color2),
	})
	if Rotation then
		Gradient.Rotation = Rotation
	end
	return Gradient
end

local function TweenProperty(Object, Properties, Duration)
	local TweenInfo = TweenInfo.new(Duration or Config.TweenSpeed, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
	local Tween = TweenService:Create(Object, TweenInfo, Properties)
	Tween:Play()
	return Tween
end

