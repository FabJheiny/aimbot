			ParagraphTitle.TextXAlignment = Enum.TextXAlignment.Left
			ParagraphTitle.Parent = ElementContent

			local ParagraphText = Instance.new("TextLabel")
			ParagraphText.Name = "ParagraphText"
			ParagraphText.Size = UDim2.new(1, 0, 1, -19)
			ParagraphText.BackgroundTransparency = 1
			ParagraphText.Text = Text or ""
			ParagraphText.TextColor3 = Theme.DisabledText
			ParagraphText.TextSize = 11
			ParagraphText.Font = Enum.Font.Gotham
			ParagraphText.TextWrapped = true
			ParagraphText.TextXAlignment = Enum.TextXAlignment.Left
			ParagraphText.TextYAlignment = Enum.TextYAlignment.Top
			ParagraphText.Parent = ElementContent

			table.insert(TabModule.Elements, Element)
			return Element
		end

		return TabModule
	end

	WindowModule.CreateTab = CreateTab

	setmetatable(WindowModule, WindowModule)
	return WindowModule
end

function Library:CreateWindow(Config)
	return CreateWindow(self, Config)
end

return Library
